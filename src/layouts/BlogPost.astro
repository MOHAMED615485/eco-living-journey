---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={heroImage?.src} />
    <script defer src="https://f.convertkit.com/ckjs/ck.5.js"></script>
  </head>
  <body>
    <Header />
    <main>
      <article>
        <div class="hero-image">
          {heroImage && (
            <img
              width={heroImage.width}
              height={heroImage.height}
              src={heroImage.src}
              alt={title}
              fetchpriority="high"
              loading="eager"
              decoding="async"
            />
          )}
        </div>
        <div class="prose">
          <div class="title">
            <div class="date">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <div class="last-updated-on">
                  Last updated on <FormattedDate date={updatedDate} />
                </div>
              )}
            </div>
            <h1>{title}</h1>
            <hr />
          </div>
          <slot />

          <div style="margin-top: 50px; border-top: 2px solid #eee; padding-top: 30px;">
            <form action="https://app.kit.com/forms/9163556/subscriptions" class="seva-form formkit-form" method="post" data-sv-form="9163556" data-uid="c7ed9c1a27" data-format="inline" data-version="5" data-options="{&quot;settings&quot;:{&quot;after_subscribe&quot;:{&quot;action&quot;:&quot;message&quot;,&quot;success_message&quot;:&quot;Success! Now check your email to confirm your subscription.&quot;,&quot;redirect_url&quot;:&quot;&quot;},&quot;analytics&quot;:{&quot;google&quot;:null,&quot;fathom&quot;:null,&quot;facebook&quot;:null,&quot;segment&quot;:null,&quot;pinterest&quot;:null,&quot;sparkloop&quot;:null,&quot;googletagmanager&quot;:null},&quot;modal&quot;:{&quot;trigger&quot;:&quot;timer&quot;,&quot;scroll_percentage&quot;:null,&quot;timer&quot;:5,&quot;devices&quot;:&quot;all&quot;,&quot;show_once_every&quot;:15},&quot;powered_by&quot;:{&quot;show&quot;:true,&quot;url&quot;:&quot;https://kit.com/features/forms?utm_campaign=poweredby&amp;utm_content=form&amp;utm_medium=referral&amp;utm_source=dynamic&quot;},&quot;recaptcha&quot;:{&quot;enabled&quot;:false},&quot;return_visitor&quot;:{&quot;action&quot;:&quot;show&quot;,&quot;custom_content&quot;:&quot;&quot;},&quot;slide_in&quot;:{&quot;display_in&quot;:&quot;bottom_right&quot;,&quot;trigger&quot;:&quot;timer&quot;,&quot;scroll_percentage&quot;:null,&quot;timer&quot;:5,&quot;devices&quot;:&quot;all&quot;,&quot;show_once_every&quot;:15},&quot;sticky_bar&quot;:{&quot;display_in&quot;:&quot;top&quot;,&quot;trigger&quot;:&quot;timer&quot;,&quot;scroll_percentage&quot;:null,&quot;timer&quot;:5,&quot;devices&quot;:&quot;all&quot;,&quot;show_once_every&quot;:15}},&quot;version&quot;:&quot;5&quot;}" min-width="400 500 600 700 800" style="background-color: rgb(249, 250, 251); border-radius: 4px;">
              <div class="formkit-background" style="opacity: 0.2;"></div>
              <div data-style="minimal">
                <div class="formkit-header" data-element="header" style="color: rgb(0, 0, 0); font-size: 21px; font-weight: 700;">
                  <h2 style="text-align:justify">The Blackout-Proof Home Checklist ⚡🏡</h2>
                </div>
                <div class="formkit-subheader" data-element="subheader" style="color: rgb(62, 62, 62); font-size: 18px;">
                  <p style="text-align:justify">Join 1,000+ homeowners receiving my exact gear list to keep their fridge, Wi-Fi, and lights running during a blackout.</p>
                </div>
                <ul class="formkit-alert formkit-alert-error" data-element="errors" data-group="alert"></ul>
                <div data-element="fields" data-stacked="false" class="seva-fields formkit-fields">
                  <div class="formkit-field">
                    <input class="formkit-input" name="email_address" aria-label="Email Address" placeholder="Email Address" required="" type="email" style="color: rgb(0, 0, 0); border-color: rgb(227, 227, 227); border-radius: 50px; font-weight: 400;">
                  </div>
                  <button data-element="submit" class="formkit-submit formkit-submit" style="color: rgb(255, 255, 255); background-color: #2d6a4f; border-radius: 50px; font-weight: 400;">
                    <div class="formkit-spinner">
                      <div></div><div></div><div></div>
                    </div>
                    <span class="">SEND ME THE CHECKLIST!</span>
                  </button>
                </div>
                <div class="formkit-guarantee" data-element="guarantee" style="color: rgb(77, 77, 77); font-size: 13px; font-weight: 400;">We won't send you spam. Unsubscribe at any time.</div>
              </div>

              <style is:inline>
                .formkit-form[data-uid="c7ed9c1a27"] *{box-sizing:border-box;}.formkit-form[data-uid="c7ed9c1a27"]{-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;}.formkit-form[data-uid="c7ed9c1a27"] legend{border:none;font-size:inherit;margin-bottom:10px;padding:0;position:relative;display:table;}.formkit-form[data-uid="c7ed9c1a27"] fieldset{border:0;padding:0.01em 0 0 0;margin:0;min-width:0;}.formkit-form[data-uid="c7ed9c1a27"] body:not(:-moz-handler-blocked) fieldset{display:table-cell;}.formkit-form[data-uid="c7ed9c1a27"] h1,.formkit-form[data-uid="c7ed9c1a27"] h2,.formkit-form[data-uid="c7ed9c1a27"] h3,.formkit-form[data-uid="c7ed9c1a27"] h4,.formkit-form[data-uid="c7ed9c1a27"] h5,.formkit-form[data-uid="c7ed9c1a27"] h6{color:inherit;font-size:inherit;font-weight:inherit;}.formkit-form[data-uid="c7ed9c1a27"] h2{font-size:1.5em;margin:1em 0;}.formkit-form[data-uid="c7ed9c1a27"] h3{font-size:1.17em;margin:1em 0;}.formkit-form[data-uid="c7ed9c1a27"] p{color:inherit;font-size:inherit;font-weight:inherit;}.formkit-form[data-uid="c7ed9c1a27"] ol:not([template-default]),.formkit-form[data-uid="c7ed9c1a27"] ul:not([template-default]),.formkit-form[data-uid="c7ed9c1a27"] blockquote:not([template-default]){text-align:left;}.formkit-form[data-uid="c7ed9c1a27"] p:not([template-default]),.formkit-form[data-uid="c7ed9c1a27"] hr:not([template-default]),.formkit-form[data-uid="c7ed9c1a27"] blockquote:not([template-default]),.formkit-form[data-uid="c7ed9c1a27"] ol:not([template-default]),.formkit-form[data-uid="c7ed9c1a27"] ul:not([template-default]){color:inherit;font-style:initial;}.formkit-form[data-uid="c7ed9c1a27"] .ordered-list,.formkit-form[data-uid="c7ed9c1a27"] .unordered-list{list-style-position:outside !important;padding-left:1em;}.formkit-form[data-uid="c7ed9c1a27"] .list-item{padding-left:0;}.formkit-form[data-uid="c7ed9c1a27"][data-format="modal"]{display:none;}.formkit-form[data-uid="c7ed9c1a27"][data-format="slide in"]{display:none;}.formkit-form[data-uid="c7ed9c1a27"][data-format="sticky bar"]{display:none;}.formkit-sticky-bar .formkit-form[data-uid="c7ed9c1a27"][data-format="sticky bar"]{display:block;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-input,.formkit-form[data-uid="c7ed9c1a27"] .formkit-select,.formkit-form[data-uid="c7ed9c1a27"] .formkit-checkboxes{width:100%;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-button,.formkit-form[data-uid="c7ed9c1a27"] .formkit-submit{border:0;border-radius:5px;color:#ffffff;cursor:pointer;display:inline-block;text-align:center;font-size:15px;font-weight:500;cursor:pointer;margin-bottom:15px;overflow:hidden;padding:0;position:relative;vertical-align:middle;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-button:hover,.formkit-form[data-uid="c7ed9c1a27"] .formkit-submit:hover,.formkit-form[data-uid="c7ed9c1a27"] .formkit-button:focus,.formkit-form[data-uid="c7ed9c1a27"] .formkit-submit:focus{outline:none;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-button:hover > span,.formkit-form[data-uid="c7ed9c1a27"] .formkit-submit:hover > span,.formkit-form[data-uid="c7ed9c1a27"] .formkit-button:focus > span,.formkit-form[data-uid="c7ed9c1a27"] .formkit-submit:focus > span{background-color:rgba(0,0,0,0.1);}.formkit-form[data-uid="c7ed9c1a27"] .formkit-button > span,.formkit-form[data-uid="c7ed9c1a27"] .formkit-submit > span{display:block;-webkit-transition:all 300ms ease-in-out;transition:all 300ms ease-in-out;padding:12px 24px;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-input{background:#ffffff;font-size:15px;padding:12px;border:1px solid #e3e3e3;-webkit-flex:1 0 auto;-ms-flex:1 0 auto;flex:1 0 auto;line-height:1.4;margin:0;-webkit-transition:border-color ease-out 300ms;transition:border-color ease-out 300ms;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-input:focus{outline:none;border-color:#1677be;-webkit-transition:border-color ease 300ms;transition:border-color ease 300ms;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-input::-webkit-input-placeholder{color:inherit;opacity:0.8;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-input::-moz-placeholder{color:inherit;opacity:0.8;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-input:-ms-input-placeholder{color:inherit;opacity:0.8;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-input::placeholder{color:inherit;opacity:0.8;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-alert{background:#f9fafb;border:1px solid #e3e3e3;border-radius:5px;-webkit-flex:1 0 auto;-ms-flex:1 0 auto;flex:1 0 auto;list-style:none;margin:25px auto;padding:12px;text-align:center;width:100%;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-alert:empty{display:none;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-alert-success{background:#d3fbeb;border-color:#10bf7a;color:#0c905c;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-alert-error{background:#fde8e2;border-color:#f2643b;color:#ea4110;} .formkit-form[data-uid="c7ed9c1a27"]{border:1px solid #e3e3e3;max-width:700px;position:relative;overflow:hidden;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-background{width:100%;height:100%;position:absolute;top:0;left:0;background-size:cover;background-position:center;opacity:0.3;}.formkit-form[data-uid="c7ed9c1a27"] [data-style="minimal"]{padding:20px;width:100%;position:relative;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-header{margin:0 0 27px 0;text-align:center;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-subheader{margin:18px 0;text-align:center;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-guarantee{font-size:13px;margin:10px 0 15px 0;text-align:center;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-fields{display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;margin:25px auto 0 auto;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-field{min-width:220px;}.formkit-form[data-uid="c7ed9c1a27"] .formkit-field,.formkit-form[data-uid="c7ed9c1a27"] .formkit-submit{margin:0 0 15px 0;-webkit-flex:1 0 100%;-ms-flex:1 0 100%;flex:1 0 100%;}
              </style>
            </form>
          </div>
        </div>
      </article>
    </main>
    <Footer />

    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box !important;
      }

      main {
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
        padding: 1rem;
        background: #ffffff;
        font-size: 1.1rem;
        line-height: 1.6;
        color: #333;
        overflow-x: hidden;
      }

      .hero-image img {
        width: 100% !important;
        height: auto !important;
        max-height: 450px !important;
        object-fit: contain !important;
        border-radius: 12px;
        background-color: #f8f9fa;
        margin-bottom: 2rem;
      }

      .prose img {
        display: block;
        margin: 2rem auto !important;
        max-width: 100% !important;
        height: auto !important;
        border-radius: 12px;
        loading: lazy;
      }

      main table {
        width: 100% !important;
        border-collapse: collapse !important;
        margin: 2rem 0;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
      }
      main th, main td {
        padding: 15px !important;
        border: 1px solid #e2e8f0 !important;
        text-align: left;
        font-size: 1rem;
      }
      main th {
        background-color: #0056b3 !important;
        color: white !important;
        font-weight: bold;
      }
      main tr:nth-child(even) {
        background-color: #f8fafc !important;
      }

      .cta-container { text-align: center; margin: 3rem 0; width: 100%; }
      .cta-button {
        display: inline-block;
        width: 95%;
        max-width: 400px;
        margin: 0 auto;
        background: #2d6a4f;
        color: white !important;
        padding: 18px 10px;
        border-radius: 50px;
        text-decoration: none !important;
        font-weight: bold;
        font-size: 1.2rem;
        box-shadow: 0 4px 12px rgba(45, 106, 79, 0.3);
        transition: transform 0.2s;
      }
      .cta-button:hover {
        transform: scale(1.05);
      }

      .author-box {
        background: #f8fafc;
        padding: 20px;
        border-radius: 10px;
        margin-top: 3rem;
        border-left: 5px solid #0056b3;
        width: 100%;
      }

      .title { margin-bottom: 2rem; }
      .title h1 { font-size: 2.5rem; line-height: 1.2; margin: 0.5rem 0; }
      .date { color: #666; font-size: 0.9rem; }
      hr { border: none; border-top: 1px solid #eee; margin: 1rem 0; }
    </style>
  </body>
</html>

