---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, heroImage } = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
       <style>
	main {
		width: calc(100% - 2em);
		max-width: 720px;
		margin: 0 auto;
		background: #ffffff;
		padding: 2rem;
		border-radius: 12px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.05);
	}
	/* CENTERS INFOGRAPHICS AND ADDS STYLE */
	.prose img {
		display: block;
		margin: 3rem auto !important; /* Forces centering */
		border-radius: 16px;
		box-shadow: 0 15px 35px rgba(0,0,0,0.1);
		max-width: 90%;
	}
	/* THE PREMIUM CTA BUTTON */
	.cta-button {
		display: block;
		width: fit-content;
		margin: 2.5rem auto;
		padding: 20px 45px;
		background: #2d5a27; /* Deep Eco Green */
		color: white !important;
		text-decoration: none !important;
		font-weight: 800;
		font-size: 1.2rem;
		border-radius: 60px;
		transition: transform 0.3s ease;
		box-shadow: 0 8px 20px rgba(45, 90, 39, 0.3);
	}
	.cta-button:hover {
		transform: scale(1.05) translateY(-3px);
		background: #3e7a36;
	}
</style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <div class="hero-image">
                    {heroImage && <img width={1020} height={510} src={heroImage.src} alt={title} />}
                </div>
                <div class="prose">
                    <div class="title">
                        <div class="date">
                            <FormattedDate date={pubDate} />
                        </div>
                        <h1>{title}</h1>
                        <hr />
                    </div>
                    <slot />
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>