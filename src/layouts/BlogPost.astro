---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, heroImage } = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
<style>
	main {
		width: calc(100% - 2em);
		max-width: 800px;
		margin: 0 auto;
		background: #ffffff;
		padding: 2rem;
		border-radius: 15px;
        /* BIG TEXT FOR EASY READING */
		font-size: 1.3rem; 
		line-height: 1.6;
		color: #333;
	}

    /* CENTER THE INFOGRAPHIC */
	.prose img[src*="infographic"] {
		display: block;
		margin: 3rem auto !important;
		border-radius: 15px;
		box-shadow: 0 10px 20px rgba(0,0,0,0.1);
	}

    /* SIMPLE, COLORFUL TABLE WITH LINES */
	.prose table {
		width: 100%;
		border: 3px solid #4caf50; /* Cheerful Green Border */
		margin: 2rem 0;
	}
	.prose th {
		background-color: #4caf50;
		color: white !important;
		padding: 15px;
		border: 1px solid #388e3c;
	}
	.prose td {
		padding: 15px;
		border: 1px solid #e0e0e0;
	}
	.prose tr:nth-child(even) {
		background-color: #f1f8e9; /* Light Green Rows */
	}

    /* CHEERFUL BUTTON */
	.cta-container { text-align: center; margin: 3rem 0; }
	.cta-button {
		display: inline-block;
		background: #ff9800; /* Cheerful Orange */
		color: white !important;
		padding: 20px 40px;
		border-radius: 50px;
		text-decoration: none !important;
		font-weight: bold;
		font-size: 1.4rem;
        box-shadow: 0 4px 15px rgba(255, 152, 0, 0.4);
	}

	.author-box {
		background: #e3f2fd; /* Cheerful Blue */
		padding: 20px;
		border-radius: 10px;
		margin-top: 3rem;
	}
</style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <div class="hero-image">
                    {heroImage && <img width={1020} height={510} src={heroImage.src} alt={title} />}
                </div>
                <div class="prose">
                    <div class="title">
                        <div class="date">
                            <FormattedDate date={pubDate} />
                        </div>
                        <h1>{title}</h1>
                        <hr />
                    </div>
                    <slot />
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>