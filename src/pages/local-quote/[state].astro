---
import states from '../../data/states.json';

export function getStaticPaths() {
  return states.map((data) => {
    return {
      params: { state: data.slug },
      props: { data },
    };
  });
}

const { data } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Premium Audit: {data.state}</title>
    <style>
      body { font-family: sans-serif; background: #f8fafc; color: #1e293b; margin: 0; padding: 0; }
      .nav { background: white; padding: 24px; text-align: center; border-bottom: 1px solid #e2e8f0; font-weight: bold; font-size: 1.5rem; }
      .container { max-width: 650px; margin: 40px auto; padding: 40px; background: white; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
      .alert { background: #fff7ed; border-left: 4px solid #ea580c; padding: 20px; margin-bottom: 25px; color: #9a3412; font-weight: 600; }
      .btn { display: block; text-align: center; background: #059669; color: white; padding: 20px; border-radius: 8px; text-decoration: none; font-weight: bold; margin-top: 30px; }
      .btn:hover { background: #047857; }
    </style>
  </head>
  <body>
    <div class="nav">EcoLiving Journey</div>
    <div class="container">
      <h1>{data.state} Grid Resilience Report</h1>
      <div class="alert">⚠️ Warning: {data.gridName} vulnerability confirmed for {data.primaryThreat}.</div>
      <p>A Level 3 system is required to maintain power during extended {data.gridName} outages.</p>
      <p><strong>Estimated Installation:</strong> {data.installCost}</p>
      <a href={`mailto:ethan@ecoliving-journey.com?subject=Audit: ${data.state}&body=Name:%0D%0APhone:%0D%0AAddress:%0D%0AAvg Bill:`} class="btn">Request My Free {data.state} Home Audit</a>
    </div>
  </body>
</html>