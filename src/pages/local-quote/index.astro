<div class="calculator-container" style="max-width: 600px; margin: 40px auto; font-family: sans-serif;">
  <h2>⚡ Free Blackout Load Calculator</h2>
  <p>Select the appliances you absolutely need to run during a grid failure. We will calculate your exact "Surge Load" so you don't buy a battery that instantly trips and shuts down.</p>
  
  <div class="appliance-list" style="margin-bottom: 25px; background: #f9fafb; padding: 20px; border-radius: 8px; border: 1px solid #e5e7eb;">
    <label style="display: block; margin-bottom: 12px; font-size: 16px; cursor: pointer;">
      <input type="checkbox" class="calc-item" data-running="150" data-surge="800"> 🧊 Full-Size Refrigerator
    </label>
    <label style="display: block; margin-bottom: 12px; font-size: 16px; cursor: pointer;">
      <input type="checkbox" class="calc-item" data-running="50" data-surge="50"> 📶 Wi-Fi Router & Modems
    </label>
    <label style="display: block; margin-bottom: 12px; font-size: 16px; cursor: pointer;">
      <input type="checkbox" class="calc-item" data-running="1500" data-surge="1500"> 🔥 Standard Space Heater
    </label>
    <label style="display: block; margin-bottom: 12px; font-size: 16px; cursor: pointer;">
      <input type="checkbox" class="calc-item" data-running="1000" data-surge="3000"> 💧 Well Pump (1/2 HP)
    </label>
    <label style="display: block; margin-bottom: 12px; font-size: 16px; cursor: pointer;">
      <input type="checkbox" class="calc-item" data-running="800" data-surge="1200"> ❄️ Window AC Unit (8,000 BTU)
    </label>
    <label style="display: block; margin-bottom: 12px; font-size: 16px; cursor: pointer;">
      <input type="checkbox" class="calc-item" data-running="100" data-surge="100"> 💡 LED Lights & Phone Chargers
    </label>
  </div>

  <button id="calc-btn" style="background: #0056b3; color: white; border: none; padding: 15px 24px; font-size: 18px; border-radius: 5px; cursor: pointer; font-weight: bold; width: 100%; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">Calculate My Blackout Load</button>

  <div id="calc-results" style="display: none; margin-top: 30px; padding: 25px; border: 2px solid #10bf7a; border-radius: 8px; background: #f0fdf4;">
    <h3 style="margin-top: 0; color: #0c905c; text-align: center;">📊 Your Custom Grid Audit:</h3>
    <p style="font-size: 18px;"><strong>Total Running Watts:</strong> <span id="running-total">0</span>W</p>
    <p style="font-size: 18px;"><strong>Total Surge Watts:</strong> <span id="surge-total">0</span>W <br><em style="color: #dc2626; font-size: 14px;">(Warning: This is the massive spike that kills cheap portable batteries instantly)</em></p>
    
    <div style="margin-top: 25px; border-top: 2px dashed #10bf7a; padding-top: 25px;">
      <p style="font-weight: bold; text-align: center; font-size: 18px;">👇 Enter your email below to instantly see which systems can safely handle your <span id="surge-highlight">0</span>W surge load without failing.</p>
      
      </div>
  </div>
</div>

<script is:inline>
  document.getElementById('calc-btn').addEventListener('click', function() {
    let totalRunning = 0;
    let totalSurge = 0;
    let checkedBoxes = document.querySelectorAll('.calc-item:checked');
    
    if (checkedBoxes.length === 0) {
      alert("Please select at least one appliance to calculate your load.");
      return;
    }

    checkedBoxes.forEach(function(checkbox) {
      totalRunning += parseInt(checkbox.getAttribute('data-running'));
      totalSurge += parseInt(checkbox.getAttribute('data-surge'));
    });
    
    document.getElementById('running-total').innerText = totalRunning.toLocaleString();
    document.getElementById('surge-total').innerText = totalSurge.toLocaleString();
    document.getElementById('surge-highlight').innerText = totalSurge.toLocaleString();
    
    document.getElementById('calc-results').style.display = 'block';
    this.style.display = 'none'; // Hides the button after calculation
  });
</script>