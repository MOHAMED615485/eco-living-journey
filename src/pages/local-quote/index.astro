---
// Blackout Load Calculator — 3-Step Wizard
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Blackout Load Calculator — Eco Living Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #f9fafb;
      --surface: #ffffff;
      --border: #e2ebe5;
      --green: #2f855a;
      --green-light: #f0fdf4;
      --green-mid: #d1fae5;
      --text: #1a202c;
      --muted: #718096;
      --amber: #d97706;
      --red: #dc2626;
      --font-display: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --radius: 16px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-body); background: var(--bg); color: var(--text); min-height: 100vh; }

    .progress-bar { position: fixed; top: 0; left: 0; right: 0; height: 4px; background: var(--border); z-index: 100; }
    .progress-fill { height: 100%; background: var(--green); transition: width 0.4s ease; }

    .step-container { display: none; min-height: 100vh; flex-direction: column; }
    .step-container.active { display: flex; }

    .step-header { padding: 40px 24px 0; max-width: 680px; margin: 0 auto; width: 100%; }
    .step-tag { display: inline-flex; align-items: center; background: var(--green-light); border: 1px solid var(--green-mid); color: var(--green); font-size: 12px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 14px; border-radius: 100px; margin-bottom: 16px; }
    .step-title { font-family: var(--font-display); font-size: clamp(26px, 5vw, 38px); font-weight: 800; line-height: 1.1; margin-bottom: 10px; }
    .step-title span { color: var(--green); }
    .step-subtitle { font-size: 16px; color: var(--muted); line-height: 1.5; }

    .step-body { flex: 1; padding: 24px; max-width: 680px; margin: 0 auto; width: 100%; }
    .step-footer { padding: 20px 24px 40px; max-width: 680px; margin: 0 auto; width: 100%; }

    .app-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .app-card { background: var(--surface); border: 2px solid var(--border); border-radius: var(--radius); padding: 18px 16px; cursor: pointer; transition: all 0.18s ease; user-select: none; position: relative; }
    .app-card:hover { border-color: #a7d7b8; background: var(--green-light); }
    .app-card.selected { border-color: var(--green); background: var(--green-light); box-shadow: 0 0 0 4px rgba(47,133,90,0.1); }
    .app-card .check { position: absolute; top: 12px; right: 12px; width: 22px; height: 22px; border: 2px solid var(--border); border-radius: 6px; background: white; display: flex; align-items: center; justify-content: center; transition: all 0.18s; }
    .app-card.selected .check { background: var(--green); border-color: var(--green); }
    .app-card.selected .check::after { content: ''; width: 10px; height: 7px; border-left: 2px solid white; border-bottom: 2px solid white; transform: rotate(-45deg) translateY(-1px); display: block; }
    .app-emoji { font-size: 28px; margin-bottom: 10px; display: block; }
    .app-label { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 4px; line-height: 1.3; padding-right: 26px; }
    .app-surge-tag { display: inline-block; margin-top: 8px; background: #fff7ed; border: 1px solid #fed7aa; color: var(--amber); font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 100px; }

    .custom-box { background: var(--surface); border: 2px dashed var(--border); border-radius: var(--radius); padding: 20px; margin-top: 12px; }
    .custom-box-title { font-size: 13px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 14px; }
    .custom-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
    .field-wrap label { display: block; font-size: 12px; color: var(--muted); margin-bottom: 5px; font-weight: 500; }
    .field-wrap input { width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 10px 14px; font-family: var(--font-body); font-size: 14px; color: var(--text); outline: none; transition: border-color 0.2s; }
    .field-wrap input:focus { border-color: var(--green); }
    .field-wrap input::placeholder { color: #c0ccc4; }
    .add-custom-btn { width: 100%; background: var(--green-light); border: 1px solid var(--green-mid); color: var(--green); border-radius: 10px; padding: 10px; font-family: var(--font-body); font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .add-custom-btn:hover { background: var(--green-mid); }

    .duration-display { text-align: center; margin: 32px 0 24px; }
    .duration-num { font-family: var(--font-display); font-size: 80px; font-weight: 800; color: var(--green); line-height: 1; }
    .duration-unit { font-size: 18px; color: var(--muted); margin-top: 6px; }

    .slider-wrap { padding: 0 8px; }
    input[type="range"] { width: 100%; -webkit-appearance: none; height: 6px; border-radius: 3px; background: var(--border); outline: none; cursor: pointer; }
    input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 28px; height: 28px; border-radius: 50%; background: var(--green); border: 3px solid white; box-shadow: 0 2px 8px rgba(47,133,90,0.4); cursor: pointer; }
    .slider-labels { display: flex; justify-content: space-between; margin-top: 10px; font-size: 12px; color: var(--muted); }

    .presets { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 28px; }
    .preset-btn { background: var(--surface); border: 2px solid var(--border); border-radius: 12px; padding: 14px 8px; text-align: center; cursor: pointer; transition: all 0.18s; font-family: var(--font-body); }
    .preset-btn:hover, .preset-btn.active { border-color: var(--green); background: var(--green-light); }
    .preset-num { font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--green); display: block; }
    .preset-label { font-size: 12px; color: var(--muted); }

    .proc-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 80vh; gap: 20px; text-align: center; }
    .proc-ring { width: 56px; height: 56px; border: 3px solid var(--border); border-top-color: var(--green); border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .proc-title { font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--text); }
    .proc-sub { font-size: 14px; color: var(--muted); }

    .verdict-box { background: var(--surface); border: 2px solid var(--border); border-radius: var(--radius); overflow: hidden; margin-bottom: 16px; }
    .verdict-stripe { height: 6px; width: 100%; }
    .verdict-content { padding: 22px; }
    .verdict-label { display: inline-block; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 4px 14px; border-radius: 100px; margin-bottom: 10px; }
    .verdict-safe { background: var(--green-light); color: var(--green); }
    .verdict-caution { background: #fffbeb; color: var(--amber); }
    .verdict-danger { background: #fef2f2; color: var(--red); }
    .verdict-title { font-family: var(--font-display); font-size: 20px; font-weight: 800; margin-bottom: 6px; }
    .verdict-desc { font-size: 14px; color: var(--muted); line-height: 1.5; }

    .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 16px; }
    .stat-box { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 18px 10px; text-align: center; }
    .stat-val { font-family: var(--font-display); font-size: 22px; font-weight: 800; line-height: 1; margin-bottom: 6px; }
    .stat-val.surge { color: var(--amber); }
    .stat-val.run { color: var(--green); }
    .stat-val.bat { color: #2563eb; }
    .stat-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }

    .breakdown { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; margin-bottom: 16px; }
    .breakdown-header { padding: 14px 18px; border-bottom: 1px solid var(--border); font-size: 12px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.07em; }
    .breakdown-row { display: flex; justify-content: space-between; align-items: center; padding: 14px 18px; border-bottom: 1px solid var(--border); font-size: 14px; gap: 16px; flex-wrap: wrap; }
    .breakdown-row:last-child { border-bottom: none; }
    .breakdown-name { font-weight: 500; flex: 1; }
    .breakdown-surge { color: var(--amber); font-weight: 700; font-size: 13px; white-space: nowrap; }
    .breakdown-run { color: var(--green); font-weight: 600; font-size: 13px; white-space: nowrap; }

    .email-box { background: linear-gradient(135deg, #f0fdf4, #dcfce7); border: 2px solid var(--green-mid); border-radius: var(--radius); padding: 28px 22px; text-align: center; margin-bottom: 16px; }
    .email-icon { font-size: 36px; margin-bottom: 12px; }
    .email-title { font-family: var(--font-display); font-size: 22px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
    .email-desc { font-size: 15px; color: var(--muted); margin-bottom: 20px; line-height: 1.5; }
    .email-bullets { list-style: none; text-align: left; margin: 0 auto 22px; display: inline-block; }
    .email-bullets li { font-size: 14px; color: var(--text); margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
    .email-bullets li::before { content: '✓'; color: var(--green); font-weight: 700; flex-shrink: 0; }

    .cta-btn { width: 100%; background: var(--green); color: white; border: none; border-radius: 14px; padding: 18px; font-family: var(--font-display); font-size: 18px; font-weight: 700; cursor: pointer; transition: all 0.2s; }
    .cta-btn:hover { background: #276749; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(47,133,90,0.3); }
    .cta-btn:disabled { background: #a0aec0; transform: none; box-shadow: none; cursor: not-allowed; }

    .back-btn { background: none; border: none; color: var(--muted); font-family: var(--font-body); font-size: 15px; cursor: pointer; display: flex; align-items: center; gap: 6px; padding: 0; margin-bottom: 16px; transition: color 0.2s; }
    .back-btn:hover { color: var(--text); }

    .selected-count { font-size: 14px; color: var(--green); font-weight: 600; text-align: center; margin-bottom: 14px; min-height: 20px; }

    /* ConvertKit */
    .formkit-header, .formkit-subheader { display: none !important; }
    .formkit-form { background: transparent !important; padding: 0 !important; box-shadow: none !important; border: none !important; max-width: 100% !important; }
    [data-style="minimal"] { background: transparent !important; padding: 0 !important; }
    .formkit-fields { flex-direction: column !important; gap: 10px !important; }
    .formkit-field { flex: none !important; }
    .formkit-input { background: white !important; border: 2px solid var(--border) !important; color: var(--text) !important; border-radius: 12px !important; padding: 14px 16px !important; font-size: 15px !important; font-family: var(--font-body) !important; width: 100% !important; }
    .formkit-input:focus { border-color: var(--green) !important; outline: none !important; }
    .formkit-submit { background: var(--green) !important; color: white !important; border-radius: 12px !important; font-family: var(--font-display) !important; font-weight: 700 !important; font-size: 17px !important; padding: 16px !important; width: 100% !important; border: none !important; cursor: pointer !important; }
    .formkit-powered-by-convertkit-container { display: none !important; }
    .formkit-guarantee { color: var(--muted) !important; font-size: 13px !important; margin-top: 12px !important; }

    @media (max-width: 420px) {
      .app-grid { grid-template-columns: 1fr 1fr; }
      .stats-row { grid-template-columns: 1fr 1fr; }
      .presets { grid-template-columns: repeat(2, 1fr); }
      .custom-fields { grid-template-columns: 1fr; }
      .duration-num { font-size: 64px; }
    }
  </style>
</head>
<body>

<div class="progress-bar">
  <div class="progress-fill" id="progress-fill" style="width: 33%"></div>
</div>

<!-- STEP 1 -->
<div class="step-container active" id="step-1">
  <div class="step-header">
    <div class="step-tag">Step 1 of 3</div>
    <h1 class="step-title">Which appliances do you<br/><span>need to power?</span></h1>
    <p class="step-subtitle">Tap everything you want running during a blackout.</p>
  </div>
  <div class="step-body">
    <div id="selected-count" class="selected-count"></div>
    <div class="app-grid" id="app-grid">
      <div class="app-card" onclick="toggleCard(this)" data-running="150" data-surge="900" data-name="Chest Freezer (7 cu. ft.)">
        <div class="check"></div><span class="app-emoji">🧊</span>
        <div class="app-label">Chest Freezer 7 cu. ft.</div>
        <div class="app-surge-tag">900W surge</div>
      </div>
      <div class="app-card" onclick="toggleCard(this)" data-running="100" data-surge="600" data-name="Chest Freezer (5 cu. ft.)">
        <div class="check"></div><span class="app-emoji">🧊</span>
        <div class="app-label">Chest Freezer 5 cu. ft.</div>
        <div class="app-surge-tag">600W surge</div>
      </div>
      <div class="app-card" onclick="toggleCard(this)" data-running="250" data-surge="1500" data-name="Chest Freezer (15 cu. ft.)">
        <div class="check"></div><span class="app-emoji">🧊</span>
        <div class="app-label">Chest Freezer 15 cu. ft.</div>
        <div class="app-surge-tag">1,500W surge</div>
      </div>
      <div class="app-card" onclick="toggleCard(this)" data-running="180" data-surge="1200" data-name="Refrigerator">
        <div class="check"></div><span class="app-emoji">🥶</span>
        <div class="app-label">Refrigerator Standard</div>
        <div class="app-surge-tag">1,200W surge</div>
      </div>
      <div class="app-card" onclick="toggleCard(this)" data-running="1500" data-surge="1500" data-name="Space Heater">
        <div class="check"></div><span class="app-emoji">🔥</span>
        <div class="app-label">Space Heater 1,500W</div>
        <div class="app-surge-tag">No surge</div>
      </div>
      <div class="app-card" onclick="toggleCard(this)" data-running="1000" data-surge="3000" data-name="Well Pump (½ HP)">
        <div class="check"></div><span class="app-emoji">💧</span>
        <div class="app-label">Well Pump ½ HP</div>
        <div class="app-surge-tag">3,000W surge</div>
      </div>
      <div class="app-card" onclick="toggleCard(this)" data-running="800" data-surge="2400" data-name="Window AC (8,000 BTU)">
        <div class="check"></div><span class="app-emoji">❄️</span>
        <div class="app-label">Window AC 8,000 BTU</div>
        <div class="app-surge-tag">2,400W surge</div>
      </div>
      <div class="app-card" onclick="toggleCard(this)" data-running="350" data-surge="1050" data-name="Sump Pump (⅓ HP)">
        <div class="check"></div><span class="app-emoji">🌀</span>
        <div class="app-label">Sump Pump ⅓ HP</div>
        <div class="app-surge-tag">1,050W surge</div>
      </div>
      <div class="app-card" onclick="toggleCard(this)" data-running="20" data-surge="20" data-name="Wi-Fi Router">
        <div class="check"></div><span class="app-emoji">📶</span>
        <div class="app-label">Wi-Fi Router</div>
        <div class="app-surge-tag">No surge</div>
      </div>
      <div class="app-card" onclick="toggleCard(this)" data-running="60" data-surge="60" data-name="LED Lights (10 bulbs)">
        <div class="check"></div><span class="app-emoji">💡</span>
        <div class="app-label">LED Lights 10 bulbs</div>
        <div class="app-surge-tag">No surge</div>
      </div>
      <div class="app-card" onclick="toggleCard(this)" data-running="400" data-surge="400" data-name="Laptop + Phone Charging">
        <div class="check"></div><span class="app-emoji">💻</span>
        <div class="app-label">Laptop + Phone</div>
        <div class="app-surge-tag">No surge</div>
      </div>
      <div class="app-card" onclick="toggleCard(this)" data-running="700" data-surge="700" data-name="Microwave">
        <div class="check"></div><span class="app-emoji">🍳</span>
        <div class="app-label">Microwave 700W</div>
        <div class="app-surge-tag">No surge</div>
      </div>
    </div>
    <div class="custom-box">
      <div class="custom-box-title">+ Add your own appliance</div>
      <div class="custom-fields">
        <div class="field-wrap">
          <label>Appliance name</label>
          <input type="text" id="c-name" placeholder="e.g. My Freezer" />
        </div>
        <div class="field-wrap">
          <label>Running watts</label>
          <input type="number" id="c-run" placeholder="e.g. 150" />
        </div>
        <div class="field-wrap">
          <label>Surge watts</label>
          <input type="number" id="c-surge" placeholder="e.g. 900" />
        </div>
        <div class="field-wrap" style="display:flex;align-items:flex-end;">
          <button class="add-custom-btn" onclick="addCustom()">Add →</button>
        </div>
      </div>
      <p style="font-size:12px;color:var(--muted);">💡 Find surge watts on your appliance data plate: LRA × Voltage</p>
    </div>
  </div>
  <div class="step-footer">
    <button class="cta-btn" id="step1-next" onclick="goStep2()" disabled>
      Next: Set Blackout Duration →
    </button>
  </div>
</div>

<!-- STEP 2 -->
<div class="step-container" id="step-2">
  <div class="step-header">
    <button class="back-btn" onclick="goStep1()">← Back</button>
    <div class="step-tag">Step 2 of 3</div>
    <h1 class="step-title">How long could your<br/><span>power be out?</span></h1>
    <p class="step-subtitle">Pick the worst-case scenario you want to be ready for.</p>
  </div>
  <div class="step-body">
    <div class="duration-display">
      <div class="duration-num" id="dur-num">24</div>
      <div class="duration-unit">hours of backup power</div>
    </div>
    <div class="slider-wrap">
      <input type="range" id="dur-slider" min="4" max="72" value="24" step="4" oninput="updateSlider(this.value)" />
      <div class="slider-labels"><span>4 hrs</span><span>24 hrs</span><span>48 hrs</span><span>72 hrs</span></div>
    </div>
    <div class="presets">
      <button class="preset-btn" onclick="setDur(8,this)"><span class="preset-num">8h</span><span class="preset-label">Storm</span></button>
      <button class="preset-btn active" onclick="setDur(24,this)"><span class="preset-num">24h</span><span class="preset-label">Common</span></button>
      <button class="preset-btn" onclick="setDur(48,this)"><span class="preset-num">48h</span><span class="preset-label">Major</span></button>
      <button class="preset-btn" onclick="setDur(72,this)"><span class="preset-num">72h</span><span class="preset-label">Crisis</span></button>
    </div>
  </div>
  <div class="step-footer">
    <button class="cta-btn" onclick="calculate()">Calculate My Results →</button>
  </div>
</div>

<!-- PROCESSING -->
<div class="step-container" id="step-proc">
  <div class="step-body">
    <div class="proc-wrap">
      <div class="proc-ring"></div>
      <div class="proc-title">Calculating your load...</div>
      <div class="proc-sub">Running surge math and battery sizing</div>
    </div>
  </div>
</div>

<!-- STEP 3 RESULTS -->
<div class="step-container" id="step-3">
  <div class="step-header">
    <button class="back-btn" onclick="goStep2()">← Recalculate</button>
    <div class="step-tag">Step 3 of 3 — Your Results</div>
    <h1 class="step-title">Your Blackout<br/><span>Audit is Ready</span></h1>
  </div>
  <div class="step-body">
    <div class="verdict-box">
      <div class="verdict-stripe" id="v-stripe"></div>
      <div class="verdict-content">
        <div class="verdict-label" id="v-label">—</div>
        <div class="verdict-title" id="v-title">—</div>
        <div class="verdict-desc" id="v-desc">—</div>
      </div>
    </div>
    <div class="stats-row">
      <div class="stat-box"><div class="stat-val surge" id="r-surge">—</div><div class="stat-label">Peak Surge</div></div>
      <div class="stat-box"><div class="stat-val run" id="r-run">—</div><div class="stat-label">Running Load</div></div>
      <div class="stat-box"><div class="stat-val bat" id="r-bat">—</div><div class="stat-label">Min Battery</div></div>
    </div>
    <div class="breakdown">
      <div class="breakdown-header">Appliance Breakdown</div>
      <div id="b-rows"></div>
    </div>
    <div class="email-box">
      <div class="email-icon">📄</div>
      <div class="email-title">Get the Free PDF Checklist</div>
      <div class="email-desc">Where should we send your <strong>Free Blackout-Proof Home Checklist PDF?</strong> Ethan will email it to you instantly.</div>
      <ul class="email-bullets">
        <li>Printable PDF checklist — ready in 60 seconds</li>
        <li>The exact steps Ethan uses to prep his own home</li>
        <li>How to keep food safe for 72+ hours without power</li>
      </ul>
      <script defer src="https://f.convertkit.com/ckjs/ck.5.js"></script>
      <form action="https://app.kit.com/forms/9204796/subscriptions" class="seva-form formkit-form" method="post" data-sv-form="9204796" data-uid="b3fe8c40d3" data-format="inline" data-version="5" data-options="{&quot;settings&quot;:{&quot;after_subscribe&quot;:{&quot;action&quot;:&quot;message&quot;,&quot;success_message&quot;:&quot;Success! Now check your email to confirm your subscription.&quot;,&quot;redirect_url&quot;:&quot;&quot;},&quot;powered_by&quot;:{&quot;show&quot;:false}}}" style="background-color:transparent;">
        <div data-style="minimal">
          <ul class="formkit-alert formkit-alert-error" data-element="errors" data-group="alert"></ul>
          <div data-element="fields" data-stacked="true" class="seva-fields formkit-fields">
            <div class="formkit-field"><input class="formkit-input" aria-label="First Name" name="fields[first_name]" required placeholder="Your first name" type="text" /></div>
            <div class="formkit-field"><input class="formkit-input" name="email_address" aria-label="Email Address" placeholder="Your email address" required type="email" /></div>
            <button data-element="submit" class="formkit-submit"><span>📄 Send Me the Free PDF →</span></button>
          </div>
          <div class="formkit-guarantee" data-element="guarantee">No spam. Unsubscribe any time.</div>
        </div>
      </form>
    </div>
  </div>
  <div class="step-footer">
    <button class="cta-btn" style="background:white;color:var(--green);border:2px solid var(--green);" onclick="restart()">↩ Start Over</button>
  </div>
</div>

<script is:inline>
  let hours = 24;

  function show(id) {
    document.querySelectorAll('.step-container').forEach(s => s.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    window.scrollTo(0,0);
    const p = {'step-1':33,'step-2':66,'step-proc':90,'step-3':100};
    document.getElementById('progress-fill').style.width = (p[id]||33)+'%';
  }

  function toggleCard(el) {
    el.classList.toggle('selected');
    const n = document.querySelectorAll('.app-card.selected').length;
    document.getElementById('selected-count').textContent = n ? n+' appliance'+(n>1?'s':'')+' selected' : '';
    document.getElementById('step1-next').disabled = n === 0;
  }

  function addCustom() {
    const name = document.getElementById('c-name').value.trim() || 'Custom Appliance';
    const run = parseInt(document.getElementById('c-run').value)||0;
    const surge = parseInt(document.getElementById('c-surge').value)||run;
    if (!run) { alert('Please enter running watts.'); return; }
    const d = document.createElement('div');
    d.className = 'app-card selected';
    d.setAttribute('data-running', run);
    d.setAttribute('data-surge', surge);
    d.setAttribute('data-name', name);
    d.onclick = function(){ toggleCard(this); };
    d.innerHTML = `<div class="check"></div><span class="app-emoji">🔌</span><div class="app-label">${name}</div><div class="app-surge-tag">${surge.toLocaleString()}W surge</div>`;
    document.getElementById('app-grid').appendChild(d);
    document.getElementById('c-name').value='';
    document.getElementById('c-run').value='';
    document.getElementById('c-surge').value='';
    const n = document.querySelectorAll('.app-card.selected').length;
    document.getElementById('selected-count').textContent = n+' appliance'+(n>1?'s':'')+' selected';
    document.getElementById('step1-next').disabled = false;
  }

  function goStep1() { show('step-1'); }
  function goStep2() { show('step-2'); }

  function updateSlider(v) {
    hours = parseInt(v);
    document.getElementById('dur-num').textContent = v;
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
  }

  function setDur(h, btn) {
    hours = h;
    document.getElementById('dur-slider').value = h;
    document.getElementById('dur-num').textContent = h;
    document.querySelectorAll('.preset-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  }

  function calculate() {
    show('step-proc');
    setTimeout(() => {
      const cards = document.querySelectorAll('.app-card.selected');
      let totalRun=0, peak=0, items=[];
      cards.forEach(c => {
        const run=parseInt(c.getAttribute('data-running'));
        const surge=parseInt(c.getAttribute('data-surge'));
        const name=c.getAttribute('data-name');
        totalRun+=run; if(surge>peak) peak=surge;
        items.push({name,run,surge});
      });

      const energy = totalRun * 0.3 * hours;
      const batWh = Math.ceil((energy * 1.25) / 0.8);

      // Breakdown
      const rows = document.getElementById('b-rows');
      rows.innerHTML = '';
      items.forEach(i => {
        const d = document.createElement('div');
        d.className = 'breakdown-row';
        d.innerHTML = `<span class="breakdown-name">${i.name}</span><span class="breakdown-run">${i.run}W</span><span class="breakdown-surge">${i.surge.toLocaleString()}W surge</span>`;
        rows.appendChild(d);
      });
      const tot = document.createElement('div');
      tot.className='breakdown-row'; tot.style.fontWeight='700'; tot.style.background='#f8faf9';
      tot.innerHTML=`<span class="breakdown-name">TOTAL</span><span class="breakdown-run">${totalRun}W</span><span class="breakdown-surge">${peak.toLocaleString()}W peak</span>`;
      rows.appendChild(tot);

      // Stats
      document.getElementById('r-surge').textContent = peak.toLocaleString()+'W';
      document.getElementById('r-run').textContent = totalRun.toLocaleString()+'W';
      document.getElementById('r-bat').textContent = batWh>=1000 ? (batWh/1000).toFixed(1)+' kWh' : batWh+'Wh';

      // Verdict
      let cls, color, title, desc;
      if (peak<=1500) { cls='verdict-safe'; color='#22c55e'; title='You\'re in good shape ✓'; desc='Your surge load is manageable. Most quality portable batteries will handle this without tripping.'; }
      else if (peak<=3000) { cls='verdict-caution'; color='#f59e0b'; title='Caution — High Surge Load ⚠'; desc='Your appliances require a high-surge battery. Many budget units will trip on startup. Choose carefully.'; }
      else { cls='verdict-danger'; color='#ef4444'; title='Danger — Extreme Surge ⛔'; desc='This load requires a professional-grade battery system. Standard portable units will fail instantly.'; }

      document.getElementById('v-stripe').style.background = color;
      document.getElementById('v-label').className = 'verdict-label '+cls;
      document.getElementById('v-label').textContent = cls==='verdict-safe'?'Safe Load':cls==='verdict-caution'?'High Surge':'Extreme Load';
      document.getElementById('v-title').textContent = title;
      document.getElementById('v-desc').textContent = desc;

      show('step-3');
    }, 2000);
  }

  function restart() {
    document.querySelectorAll('.app-card').forEach(c => c.classList.remove('selected'));
    document.getElementById('selected-count').textContent = '';
    document.getElementById('step1-next').disabled = true;
    document.getElementById('dur-slider').value = 24;
    hours = 24;
    document.getElementById('dur-num').textContent = '24';
    document.querySelectorAll('.preset-btn').forEach((b,i) => b.classList.toggle('active', i===1));
    show('step-1');
  }
</script>

</body>
</html>
