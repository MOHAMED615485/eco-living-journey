---
import states from '../../data/states.json';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Select Your State - Off-Grid Blueprint</title>
    <style>
      body { font-family: 'Arial', sans-serif; line-height: 1.6; color: #333; max-width: 800px; margin: 0 auto; padding: 40px 20px; text-align: center; }
      h1 { color: #0056b3; margin-bottom: 10px; }
      p { font-size: 1.1rem; margin-bottom: 30px; color: #555; }
      .grid-container { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; }
      .state-button { 
        display: block; 
        background: #28a745; 
        color: white; 
        padding: 15px; 
        text-decoration: none; 
        font-size: 1.2rem; 
        font-weight: bold; 
        border-radius: 8px; 
        transition: background 0.3s ease;
      }
      .state-button:hover { background: #218838; }
      
      /* Special styling for the catch-all button */
      .other-button {
        background: #0056b3; 
      }
      .other-button:hover {
        background: #004494;
      }
    </style>
  </head>
  <body>
    
    <h1>Initiate Your Home Audit</h1>
    <p>Select your state below to view local grid threats and connect with a certified off-grid installer in your area.</p>

    <div class="grid-container">
      {states.map((data) => (
        <a href={`/local-quote/${data.slug}`} class="state-button">
          {data.state}
        </a>
      ))}
      
      <a href="mailto:quotes@ecoliving-journey.com?subject=Custom Home Audit Request - Unlisted State" class="state-button other-button">
        Other
      </a>
    </div>

  </body>
</html>