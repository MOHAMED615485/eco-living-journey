---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
<script is:inline src="https://f.convertkit.com/ckjs/ck.5.js"></script>
  <body>
    <Header />
    <main>
      <article>
        <div class="hero-image">
          {heroImage && <img width={heroImage.width} height={heroImage.height} src={heroImage.src} alt="" />}
        </div>
        <div class="prose">
          <div class="title">
            <div class="date">
              <FormattedDate date={pubDate} />
              {
                updatedDate && (
                  <div class="last-updated-on">
                    Last updated on <FormattedDate date={updatedDate} />
                  </div>
                )
              }
            </div>
            <h1>{title}</h1>
            <hr />
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />

    <style is:global>
      /* 1. MAGIC RULE: STOPS ANYTHING FROM PUSHING OFF THE SCREEN */
      *, *::before, *::after {
        box-sizing: border-box !important;
      }

      main {
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
        padding: 1rem; 
        background: #ffffff;
        font-size: 1.1rem; /* Professional reading size */
        line-height: 1.6;
        color: #333;
        overflow-x: hidden;
      }

      /* 2. HERO IMAGE FIX: STOPS THE ZOOMING AND BLURRINESS */
      .hero-image img {
        width: 100% !important;
        height: auto !important;
        max-height: 450px !important;
        object-fit: contain !important; /* Forces the whole image to show */
        border-radius: 12px;
        background-color: #f8f9fa; /* Clean backdrop */
        margin-bottom: 2rem;
      }

      /* 3. NORMAL BLOG IMAGES */
      .prose img {
        display: block;
        margin: 2rem auto !important;
        max-width: 100% !important;
        height: auto !important;
        border-radius: 12px;
      }

      /* 4. PROFESSIONAL TABLES (TRUST BLUE) */
      main table {
        width: 100% !important;
        border-collapse: collapse !important; 
        margin: 2rem 0;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
      }
      main th, main td {
        padding: 15px !important;
        border: 1px solid #e2e8f0 !important; 
        text-align: left;
        font-size: 1rem;
      }
      main th {
        background-color: #0056b3 !important; /* Premium Trust Blue */
        color: white !important;
        font-weight: bold;
      }
      main tr:nth-child(even) {
        background-color: #f8fafc !important; 
      }

      /* 5. CTA BUTTON (PREMIUM DESIGN) */
      .cta-container { text-align: center; margin: 3rem 0; width: 100%; }
      .cta-button {
        display: inline-block;
        width: 95%; 
        max-width: 400px; /* Stops button from being too wide on PC */
        margin: 0 auto;
        background: #0056b3; /* Premium Trust Blue */
        color: white !important;
        padding: 18px 10px;
        border-radius: 50px;
        text-decoration: none !important;
        font-weight: bold;
        font-size: 1.2rem;
        box-shadow: 0 4px 12px rgba(0, 86, 179, 0.3);
        transition: transform 0.2s;
      }
      .cta-button:hover {
        transform: scale(1.05); /* Slight pop when hovered */
      }

      /* 6. AUTHOR BOX */
      .author-box {
        background: #f8fafc;
        padding: 20px;
        border-radius: 10px;
        margin-top: 3rem;
        border-left: 5px solid #0056b3;
        width: 100%;
      }

      .title { margin-bottom: 2rem; }
      .title h1 { font-size: 2.5rem; line-height: 1.2; margin: 0.5rem 0; }
      .date { color: #666; font-size: 0.9rem; }
      hr { border: none; border-top: 1px solid #eee; margin: 1rem 0; }
    </style>
  </body>
</html>
<script is:inline src="https://f.convertkit.com/ckjs/ck.5.js"></script>