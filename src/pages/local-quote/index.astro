---
// Premium Blackout Load Calculator
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Blackout Load Calculator — Eco Living Journey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #0a0f0d;
      --surface: #111a16;
      --surface2: #172118;
      --border: #1e2f23;
      --green: #22c55e;
      --green-dim: #16a34a;
      --green-glow: rgba(34,197,94,0.15);
      --amber: #f59e0b;
      --red: #ef4444;
      --text: #e8f0eb;
      --muted: #6b8a73;
      --font-display: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-body);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 0 0 80px 0;
    }

    /* Hero Header */
    .hero {
      position: relative;
      text-align: center;
      padding: 60px 24px 48px;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -60px; left: 50%;
      transform: translateX(-50%);
      width: 600px; height: 300px;
      background: radial-gradient(ellipse, rgba(34,197,94,0.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--green-glow);
      border: 1px solid rgba(34,197,94,0.3);
      color: var(--green);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 24px;
    }
    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(32px, 6vw, 58px);
      font-weight: 800;
      line-height: 1.05;
      color: #fff;
      margin-bottom: 16px;
      letter-spacing: -0.02em;
    }
    .hero h1 span { color: var(--green); }
    .hero p {
      max-width: 560px;
      margin: 0 auto;
      color: var(--muted);
      font-size: 17px;
      line-height: 1.6;
    }

    /* Main Layout */
    .calc-layout {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 20px;
      display: grid;
      gap: 20px;
    }

    /* Cards */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px;
    }
    .card-title {
      font-family: var(--font-display);
      font-size: 16px;
      font-weight: 700;
      color: var(--green);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .card-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* Voltage Selector */
    .voltage-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .voltage-btn {
      background: var(--surface2);
      border: 2px solid var(--border);
      border-radius: 12px;
      padding: 16px;
      cursor: pointer;
      transition: all 0.2s;
      text-align: left;
      color: var(--text);
    }
    .voltage-btn.active {
      border-color: var(--green);
      background: var(--green-glow);
    }
    .voltage-btn .v-label {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 700;
      color: var(--green);
      display: block;
    }
    .voltage-btn .v-desc {
      font-size: 13px;
      color: var(--muted);
      margin-top: 4px;
    }

    /* Appliance List */
    .appliance-list { display: flex; flex-direction: column; gap: 10px; }

    .appliance-item {
      background: var(--surface2);
      border: 2px solid var(--border);
      border-radius: 12px;
      padding: 16px 20px;
      cursor: pointer;
      transition: all 0.2s;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 16px;
    }
    .appliance-item:hover { border-color: rgba(34,197,94,0.3); }
    .appliance-item.selected {
      border-color: var(--green);
      background: var(--green-glow);
    }

    .app-check {
      width: 22px; height: 22px;
      border: 2px solid var(--border);
      border-radius: 6px;
      background: var(--surface);
      display: flex; align-items: center; justify-content: center;
      transition: all 0.2s;
      flex-shrink: 0;
    }
    .appliance-item.selected .app-check {
      background: var(--green);
      border-color: var(--green);
    }
    .app-check svg { opacity: 0; transition: opacity 0.15s; }
    .appliance-item.selected .app-check svg { opacity: 1; }

    .app-info { min-width: 0; }
    .app-name {
      font-weight: 600;
      font-size: 15px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .app-name .emoji { font-size: 18px; }
    .app-watts {
      font-size: 12px;
      color: var(--muted);
      margin-top: 3px;
    }

    .app-surge {
      text-align: right;
      flex-shrink: 0;
    }
    .surge-val {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 700;
      color: var(--amber);
    }
    .surge-label {
      font-size: 11px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    /* Custom Appliance */
    .custom-row {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr auto;
      gap: 10px;
      align-items: end;
      margin-top: 12px;
    }
    .field-group label {
      display: block;
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 6px;
    }
    .field-group input {
      width: 100%;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 14px;
      color: var(--text);
      font-family: var(--font-body);
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s;
    }
    .field-group input:focus { border-color: var(--green); }
    .field-group input::placeholder { color: var(--muted); }
    .add-btn {
      background: var(--green-glow);
      border: 1px solid rgba(34,197,94,0.4);
      color: var(--green);
      border-radius: 8px;
      padding: 10px 18px;
      cursor: pointer;
      font-weight: 600;
      font-size: 14px;
      white-space: nowrap;
      transition: all 0.2s;
    }
    .add-btn:hover { background: rgba(34,197,94,0.25); }

    /* Runtime */
    .runtime-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    /* Calculate Button */
    .calc-btn {
      width: 100%;
      background: var(--green);
      color: #0a0f0d;
      border: none;
      border-radius: 12px;
      padding: 20px;
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
      letter-spacing: 0.02em;
      position: relative;
      overflow: hidden;
    }
    .calc-btn:hover {
      background: #4ade80;
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(34,197,94,0.3);
    }
    .calc-btn:active { transform: translateY(0); }

    /* Processing */
    #processing {
      display: none;
      text-align: center;
      padding: 60px 20px;
    }
    .proc-ring {
      width: 64px; height: 64px;
      border: 3px solid var(--border);
      border-top-color: var(--green);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 20px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .proc-text {
      font-family: var(--font-display);
      font-size: 20px;
      color: var(--green);
    }
    .proc-sub { color: var(--muted); font-size: 14px; margin-top: 8px; }

    /* Results */
    #results-panel { display: none; }

    .result-hero {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 32px;
      text-align: center;
      position: relative;
      overflow: hidden;
      margin-bottom: 20px;
    }
    .result-hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--green), var(--amber), var(--red));
    }

    .verdict-badge {
      display: inline-block;
      padding: 6px 18px;
      border-radius: 100px;
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 16px;
    }
    .verdict-safe { background: rgba(34,197,94,0.15); color: var(--green); border: 1px solid rgba(34,197,94,0.3); }
    .verdict-caution { background: rgba(245,158,11,0.15); color: var(--amber); border: 1px solid rgba(245,158,11,0.3); }
    .verdict-danger { background: rgba(239,68,68,0.15); color: var(--red); border: 1px solid rgba(239,68,68,0.3); }

    .result-nums {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin: 24px 0;
    }
    .num-box {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px 12px;
    }
    .num-val {
      font-family: var(--font-display);
      font-size: 28px;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 6px;
    }
    .num-val.surge-color { color: var(--amber); }
    .num-val.run-color { color: var(--green); }
    .num-val.bat-color { color: #60a5fa; }
    .num-label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }

    /* Appliance breakdown */
    .breakdown-table { width: 100%; border-collapse: collapse; }
    .breakdown-table th {
      text-align: left;
      font-size: 11px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
    }
    .breakdown-table td {
      padding: 14px;
      border-bottom: 1px solid var(--border);
      font-size: 14px;
    }
    .breakdown-table tr:last-child td { border-bottom: none; }
    .breakdown-table .td-surge { color: var(--amber); font-weight: 700; font-family: var(--font-display); }
    .breakdown-table .td-run { color: var(--green); font-weight: 600; }

    /* Recommendation cards */
    .rec-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; }
    .rec-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 22px;
      position: relative;
    }
    .rec-card.top-pick {
      border-color: var(--green);
    }
    .top-pick-badge {
      position: absolute;
      top: -1px; right: 16px;
      background: var(--green);
      color: #0a0f0d;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 4px 12px;
      border-radius: 0 0 8px 8px;
    }
    .rec-name {
      font-family: var(--font-display);
      font-size: 17px;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .rec-capacity {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 14px;
    }
    .rec-stats { display: flex; flex-direction: column; gap: 8px; }
    .rec-stat { display: flex; justify-content: space-between; align-items: center; font-size: 13px; }
    .rec-stat-label { color: var(--muted); }
    .rec-stat-val { font-weight: 600; }
    .rec-stat-val.ok { color: var(--green); }
    .rec-stat-val.warn { color: var(--amber); }
    .rec-stat-val.bad { color: var(--red); }
    .rec-link {
      display: block;
      text-align: center;
      margin-top: 16px;
      background: var(--green-glow);
      border: 1px solid rgba(34,197,94,0.3);
      color: var(--green);
      text-decoration: none;
      padding: 10px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 14px;
      transition: all 0.2s;
    }
    .rec-link:hover { background: rgba(34,197,94,0.2); }

    /* Tips */
    .tips-list { display: flex; flex-direction: column; gap: 10px; }
    .tip-item {
      display: flex;
      gap: 14px;
      align-items: flex-start;
      padding: 14px;
      background: var(--surface2);
      border-radius: 10px;
      border: 1px solid var(--border);
    }
    .tip-icon { font-size: 20px; flex-shrink: 0; margin-top: 2px; }
    .tip-text { font-size: 14px; line-height: 1.5; color: var(--text); }
    .tip-text strong { color: var(--green); }

    /* Email capture */
    .email-capture {
      background: linear-gradient(135deg, #0f2318, #0a1a10);
      border: 1px solid rgba(34,197,94,0.3);
      border-radius: 16px;
      padding: 32px;
      text-align: center;
    }
    .email-capture h3 {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 800;
      color: #fff;
      margin-bottom: 8px;
    }
    .email-capture p { color: var(--muted); font-size: 15px; margin-bottom: 24px; }

    .reset-btn {
      display: block;
      width: 100%;
      background: transparent;
      border: 1px solid var(--border);
      color: var(--muted);
      border-radius: 10px;
      padding: 14px;
      font-family: var(--font-body);
      font-size: 15px;
      cursor: pointer;
      margin-top: 16px;
      transition: all 0.2s;
    }
    .reset-btn:hover { border-color: var(--green); color: var(--green); }

    /* Responsive */
    @media (max-width: 600px) {
      .custom-row { grid-template-columns: 1fr 1fr; }
      .custom-row .add-btn { grid-column: 1/-1; }
      .result-nums { grid-template-columns: 1fr 1fr; }
      .voltage-grid { grid-template-columns: 1fr; }
      .runtime-grid { grid-template-columns: 1fr; }
    }

    /* ConvertKit overrides */
    .formkit-header, .formkit-subheader { display: none !important; }
    .formkit-form, [data-style="minimal"] { background: transparent !important; padding: 0 !important; box-shadow: none !important; border: none !important; }
    .formkit-input {
      background: var(--surface2) !important;
      border: 1px solid var(--border) !important;
      color: var(--text) !important;
      border-radius: 8px !important;
      padding: 14px !important;
      font-size: 15px !important;
    }
    .formkit-input:focus { border-color: var(--green) !important; outline: none !important; }
    .formkit-submit {
      background: var(--green) !important;
      color: #0a0f0d !important;
      border-radius: 8px !important;
      font-weight: 700 !important;
      padding: 14px !important;
      font-size: 16px !important;
    }
    .formkit-powered-by-convertkit-container { display: none !important; }
    .formkit-guarantee { color: var(--muted) !important; font-size: 13px !important; }
  </style>
</head>
<body>

<!-- Hero -->
<div class="hero">
  <div class="hero-badge">⚡ Free Tool</div>
  <h1>Blackout <span>Load</span><br/>Calculator</h1>
  <p>Enter your appliances and get the exact surge capacity, battery size, and runtime you need — no guessing.</p>
</div>

<div class="calc-layout">

  <!-- Step 1: Voltage -->
  <div class="card" id="step-voltage">
    <div class="card-title">① Grid Voltage</div>
    <div class="voltage-grid">
      <button class="voltage-btn active" onclick="setVoltage(120, this)">
        <span class="v-label">120V</span>
        <span class="v-desc">Standard US — most homes, fridges, freezers, lights</span>
      </button>
      <button class="voltage-btn" onclick="setVoltage(240, this)">
        <span class="v-label">240V</span>
        <span class="v-desc">Heavy-duty — central AC, well pumps, dryers</span>
      </button>
    </div>
  </div>

  <!-- Step 2: Appliances -->
  <div class="card">
    <div class="card-title">② Select Appliances</div>
    <div class="appliance-list" id="appliance-list">

      <div class="appliance-item" onclick="toggleApp(this)" data-running="150" data-surge="900" data-lra="7.5">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">🧊</span>Chest Freezer (7 cu. ft.)</div>
          <div class="app-watts">Running: 150W — LRA: 7.5A @ 120V</div>
        </div>
        <div class="app-surge"><div class="surge-val">900W</div><div class="surge-label">Surge</div></div>
      </div>

      <div class="appliance-item" onclick="toggleApp(this)" data-running="100" data-surge="600" data-lra="5.0">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">🧊</span>Chest Freezer (5 cu. ft.)</div>
          <div class="app-watts">Running: 100W — LRA: 5.0A @ 120V</div>
        </div>
        <div class="app-surge"><div class="surge-val">600W</div><div class="surge-label">Surge</div></div>
      </div>

      <div class="appliance-item" onclick="toggleApp(this)" data-running="250" data-surge="1500" data-lra="12.5">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">🧊</span>Chest Freezer (15 cu. ft.)</div>
          <div class="app-watts">Running: 250W — LRA: 12.5A @ 120V</div>
        </div>
        <div class="app-surge"><div class="surge-val">1,500W</div><div class="surge-label">Surge</div></div>
      </div>

      <div class="appliance-item" onclick="toggleApp(this)" data-running="180" data-surge="1200" data-lra="10.0">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">🥶</span>Refrigerator (Standard)</div>
          <div class="app-watts">Running: 180W — LRA: 10.0A @ 120V</div>
        </div>
        <div class="app-surge"><div class="surge-val">1,200W</div><div class="surge-label">Surge</div></div>
      </div>

      <div class="appliance-item" onclick="toggleApp(this)" data-running="1500" data-surge="1500" data-lra="0">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">🔥</span>Space Heater (1500W)</div>
          <div class="app-watts">Running: 1,500W — No surge (resistive load)</div>
        </div>
        <div class="app-surge"><div class="surge-val">1,500W</div><div class="surge-label">Surge</div></div>
      </div>

      <div class="appliance-item" onclick="toggleApp(this)" data-running="1000" data-surge="3000" data-lra="25.0">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">💧</span>Well Pump (½ HP)</div>
          <div class="app-watts">Running: 1,000W — LRA: 25.0A @ 120V</div>
        </div>
        <div class="app-surge"><div class="surge-val">3,000W</div><div class="surge-label">Surge</div></div>
      </div>

      <div class="appliance-item" onclick="toggleApp(this)" data-running="800" data-surge="2400" data-lra="20.0">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">❄️</span>Window AC (8,000 BTU)</div>
          <div class="app-watts">Running: 800W — LRA: 20.0A @ 120V</div>
        </div>
        <div class="app-surge"><div class="surge-val">2,400W</div><div class="surge-label">Surge</div></div>
      </div>

      <div class="appliance-item" onclick="toggleApp(this)" data-running="20" data-surge="20" data-lra="0">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">📶</span>Wi-Fi Router</div>
          <div class="app-watts">Running: 20W — No surge</div>
        </div>
        <div class="app-surge"><div class="surge-val">20W</div><div class="surge-label">Surge</div></div>
      </div>

      <div class="appliance-item" onclick="toggleApp(this)" data-running="60" data-surge="60" data-lra="0">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">💡</span>LED Lights (10 bulbs)</div>
          <div class="app-watts">Running: 60W — No surge</div>
        </div>
        <div class="app-surge"><div class="surge-val">60W</div><div class="surge-label">Surge</div></div>
      </div>

      <div class="appliance-item" onclick="toggleApp(this)" data-running="400" data-surge="400" data-lra="0">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">💻</span>Laptop + Phone Charging</div>
          <div class="app-watts">Running: 400W — No surge</div>
        </div>
        <div class="app-surge"><div class="surge-val">400W</div><div class="surge-label">Surge</div></div>
      </div>

      <div class="appliance-item" onclick="toggleApp(this)" data-running="350" data-surge="1050" data-lra="8.75">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">🌀</span>Sump Pump (⅓ HP)</div>
          <div class="app-watts">Running: 350W — LRA: 8.75A @ 120V</div>
        </div>
        <div class="app-surge"><div class="surge-val">1,050W</div><div class="surge-label">Surge</div></div>
      </div>

      <div class="appliance-item" onclick="toggleApp(this)" data-running="700" data-surge="700" data-lra="0">
        <div class="app-check"><svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <div class="app-info">
          <div class="app-name"><span class="emoji">🍳</span>Microwave (700W)</div>
          <div class="app-watts">Running: 700W — No motor surge</div>
        </div>
        <div class="app-surge"><div class="surge-val">700W</div><div class="surge-label">Surge</div></div>
      </div>

    </div>

    <!-- Custom Appliance -->
    <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--border);">
      <div class="card-title" style="font-size:13px; margin-bottom:14px;">Add Custom Appliance</div>
      <div class="custom-row">
        <div class="field-group">
          <label>Name</label>
          <input type="text" id="custom-name" placeholder="e.g. My Freezer" />
        </div>
        <div class="field-group">
          <label>Running Watts</label>
          <input type="number" id="custom-running" placeholder="e.g. 150" min="1" />
        </div>
        <div class="field-group">
          <label>Surge Watts</label>
          <input type="number" id="custom-surge" placeholder="e.g. 900" min="1" />
        </div>
        <button class="add-btn" onclick="addCustom()">+ Add</button>
      </div>
      <p style="font-size:12px; color:var(--muted); margin-top:8px;">💡 Tip: Find surge watts on your appliance's data plate. Multiply LRA × Voltage.</p>
    </div>
  </div>

  <!-- Step 3: Blackout Duration -->
  <div class="card">
    <div class="card-title">③ Expected Blackout Duration</div>
    <div class="runtime-grid">
      <div class="field-group">
        <label>Hours of backup needed</label>
        <input type="number" id="hours-needed" value="24" min="1" max="168" placeholder="24" />
      </div>
      <div class="field-group">
        <label>Compressor duty cycle %</label>
        <input type="number" id="duty-cycle" value="30" min="10" max="80" placeholder="30" />
      </div>
    </div>
    <p style="font-size:12px; color:var(--muted); margin-top:10px;">💡 A well-stocked chest freezer runs its compressor ~25–35% of the time. Hot weather = higher duty cycle.</p>
  </div>

  <!-- Calculate Button -->
  <button class="calc-btn" onclick="runCalculator()">
    ⚡ Calculate My Exact Blackout Requirements →
  </button>

  <!-- Processing -->
  <div id="processing" class="card" style="text-align:center; padding: 50px;">
    <div class="proc-ring"></div>
    <div class="proc-text">Calculating Surge Load...</div>
    <div class="proc-sub">Computing LRA, runtime, and battery recommendations</div>
  </div>

  <!-- Results -->
  <div id="results-panel">

    <!-- Summary Numbers -->
    <div class="result-hero">
      <div id="verdict-badge" class="verdict-badge verdict-caution">Analyzing...</div>
      <h2 style="font-family: var(--font-display); font-size: 26px; font-weight: 800; color: #fff; margin-bottom: 8px;">Your Blackout Audit Results</h2>
      <p id="verdict-text" style="color: var(--muted); font-size: 15px;">—</p>
      <div class="result-nums">
        <div class="num-box">
          <div class="num-val surge-color" id="r-surge">—</div>
          <div class="num-label">Peak Surge Required</div>
        </div>
        <div class="num-box">
          <div class="num-val run-color" id="r-running">—</div>
          <div class="num-label">Continuous Running</div>
        </div>
        <div class="num-box">
          <div class="num-val bat-color" id="r-battery">—</div>
          <div class="num-label">Min Battery Size</div>
        </div>
      </div>
    </div>

    <!-- Appliance Breakdown -->
    <div class="card" style="margin-bottom:20px;">
      <div class="card-title">Appliance Breakdown</div>
      <div style="overflow-x:auto;">
        <table class="breakdown-table">
          <thead>
            <tr>
              <th>Appliance</th>
              <th>Running</th>
              <th>Surge</th>
              <th>24h Energy</th>
            </tr>
          </thead>
          <tbody id="breakdown-body"></tbody>
        </table>
      </div>
    </div>

    <!-- Battery Recommendations -->
    <div class="card" style="margin-bottom:20px;">
      <div class="card-title">Recommended Batteries</div>
      <div class="rec-grid" id="rec-grid"></div>
    </div>

    <!-- Pro Tips -->
    <div class="card" style="margin-bottom:20px;">
      <div class="card-title">Survival Tips</div>
      <div class="tips-list">
        <div class="tip-item">
          <div class="tip-icon">🧊</div>
          <div class="tip-text"><strong>Fill empty freezer space</strong> with frozen water bottles. Thermal mass keeps food frozen 2–3× longer when the compressor isn't running.</div>
        </div>
        <div class="tip-item">
          <div class="tip-icon">🛋️</div>
          <div class="tip-text"><strong>Blanket your freezer.</strong> Throw heavy moving blankets over the top and sides (not over compressor vents) to add insulation and cut duty cycle.</div>
        </div>
        <div class="tip-item">
          <div class="tip-icon">🪙</div>
          <div class="tip-text"><strong>Use the coin-in-cup test.</strong> Freeze a cup of water with a coin on top. If you return and the coin is at the bottom, your food thawed and refroze — don't eat it.</div>
        </div>
        <div class="tip-item">
          <div class="tip-icon">⚡</div>
          <div class="tip-text"><strong>Never daisy-chain extension cords.</strong> The surge from a compressor can overheat undersized cords and start a fire. Use a heavy-duty 12-gauge cord rated for your surge load.</div>
        </div>
      </div>
    </div>

    <!-- Email Capture -->
    <div class="email-capture">
      <h3>📋 Save Your Results + Get the Gear List</h3>
      <p>Get your custom results emailed plus my exact gear list for blackout preparedness.</p>
      <script defer src="https://f.convertkit.com/ckjs/ck.5.js"></script>
      <form action="https://app.kit.com/forms/9204796/subscriptions" class="seva-form formkit-form" method="post" data-sv-form="9204796" data-uid="b3fe8c40d3" data-format="inline" data-version="5" data-options="{&quot;settings&quot;:{&quot;after_subscribe&quot;:{&quot;action&quot;:&quot;message&quot;,&quot;success_message&quot;:&quot;Success! Now check your email to confirm your subscription.&quot;,&quot;redirect_url&quot;:&quot;&quot;},&quot;powered_by&quot;:{&quot;show&quot;:false}}}" style="background-color: transparent;">
        <div data-style="minimal">
          <ul class="formkit-alert formkit-alert-error" data-element="errors" data-group="alert"></ul>
          <div data-element="fields" data-stacked="true" class="seva-fields formkit-fields">
            <div class="formkit-field">
              <input class="formkit-input" aria-label="First Name" name="fields[first_name]" required placeholder="First Name" type="text" />
            </div>
            <div class="formkit-field">
              <input class="formkit-input" name="email_address" aria-label="Email Address" placeholder="Email Address" required type="email" />
            </div>
            <button data-element="submit" class="formkit-submit" style="color:#0a0f0d; background-color:#22c55e; border-radius:8px; font-weight:700;">
              <span>Send My Results →</span>
            </button>
          </div>
          <div class="formkit-guarantee" data-element="guarantee">We won't send you spam. Unsubscribe at any time.</div>
        </div>
      </form>
    </div>

    <button class="reset-btn" onclick="resetCalc()">↩ Start Over / Recalculate</button>

  </div>

</div>

<script is:inline>
  let selectedVoltage = 120;

  function setVoltage(v, btn) {
    selectedVoltage = v;
    document.querySelectorAll('.voltage-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  }

  function toggleApp(el) {
    el.classList.toggle('selected');
  }

  function addCustom() {
    const name = document.getElementById('custom-name').value.trim() || 'Custom Appliance';
    const running = parseInt(document.getElementById('custom-running').value) || 0;
    const surge = parseInt(document.getElementById('custom-surge').value) || running;
    if (!running) { alert('Please enter running watts.'); return; }

    const list = document.getElementById('appliance-list');
    const div = document.createElement('div');
    div.className = 'appliance-item selected';
    div.setAttribute('data-running', running);
    div.setAttribute('data-surge', surge);
    div.setAttribute('data-lra', '0');
    div.onclick = function() { toggleApp(this); };
    div.innerHTML = `
      <div class="app-check" style="background:var(--green);border-color:var(--green);">
        <svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3.5 3.5L11 1" stroke="#0a0f0d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div class="app-info">
        <div class="app-name"><span class="emoji">🔌</span>${name}</div>
        <div class="app-watts">Running: ${running}W — Custom</div>
      </div>
      <div class="app-surge">
        <div class="surge-val">${surge.toLocaleString()}W</div>
        <div class="surge-label">Surge</div>
      </div>`;
    list.appendChild(div);

    document.getElementById('custom-name').value = '';
    document.getElementById('custom-running').value = '';
    document.getElementById('custom-surge').value = '';
  }

  function runCalculator() {
    const selected = document.querySelectorAll('.appliance-item.selected');
    if (selected.length === 0) {
      alert('Please select at least one appliance.');
      return;
    }

    const hours = parseInt(document.getElementById('hours-needed').value) || 24;
    const duty = (parseInt(document.getElementById('duty-cycle').value) || 30) / 100;

    // Hide form, show processing
    document.getElementById('step-voltage').style.display = 'none';
    document.querySelectorAll('.card').forEach(c => {
      if (!c.id || c.id === 'processing') return;
      c.style.display = 'none';
    });
    document.querySelectorAll('.calc-btn').forEach(b => b.style.display = 'none');
    document.getElementById('processing').style.display = 'block';

    setTimeout(() => {
      // Collect data
      let totalRunning = 0;
      let peakSurge = 0;
      let applianceData = [];

      selected.forEach(item => {
        const running = parseInt(item.getAttribute('data-running'));
        const surge = parseInt(item.getAttribute('data-surge'));
        const name = item.querySelector('.app-name').innerText;
        totalRunning += running;
        if (surge > peakSurge) peakSurge = surge;

        // Energy per 24h (motors have duty cycle, resistive loads run full time)
        const lra = parseFloat(item.getAttribute('data-lra'));
        const hasMotor = lra > 0;
        const activeHours = hasMotor ? hours * duty : hours;
        const energy = (running * activeHours / 1000).toFixed(2);

        applianceData.push({ name, running, surge, energy });
      });

      // Battery math: total energy needed + 20% buffer + only usable 80% of LiFePO4
      let totalEnergy = 0;
      applianceData.forEach(a => totalEnergy += parseFloat(a.energy));
      const batteryNeeded = Math.ceil((totalEnergy * 1.2) / 0.8 * 1000); // in Wh

      // Populate breakdown
      const tbody = document.getElementById('breakdown-body');
      tbody.innerHTML = '';
      applianceData.forEach(a => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${a.name}</td>
          <td class="td-run">${a.running}W</td>
          <td class="td-surge">${a.surge.toLocaleString()}W</td>
          <td style="color:#94a3b8">${a.energy} kWh</td>`;
        tbody.appendChild(tr);
      });

      // Add totals row
      const totRow = document.createElement('tr');
      totRow.style.background = 'var(--surface2)';
      totRow.innerHTML = `
        <td style="font-weight:700;">TOTAL</td>
        <td class="td-run" style="font-weight:700;">${totalRunning}W</td>
        <td class="td-surge" style="font-weight:700;">${peakSurge.toLocaleString()}W</td>
        <td style="color:#94a3b8;font-weight:700;">${totalEnergy.toFixed(2)} kWh</td>`;
      tbody.appendChild(totRow);

      // Battery recommendations
      const batteries = [
        { name: 'EcoFlow DELTA 2', wh: 1024, surge: 2700, link: 'https://amzn.to/4boW99s', topPick: false },
        { name: 'EcoFlow DELTA Pro', wh: 3600, surge: 7200, link: 'https://amzn.to/3DELTA', topPick: false },
        { name: 'Jackery Explorer 1000 v2', wh: 1070, surge: 2000, link: 'https://amzn.to/4rA9JNl', topPick: false },
        { name: 'Bluetti AC200MAX', wh: 2048, surge: 4800, link: 'https://amzn.to/bluetti', topPick: false },
        { name: 'Anker SOLIX C800', wh: 768, surge: 1600, link: 'https://amzn.to/anker', topPick: false },
      ];

      // Filter and rank
      const suitable = batteries.filter(b => b.surge >= peakSurge && b.wh >= batteryNeeded * 0.7);
      if (suitable.length > 0) suitable[0].topPick = true;
      const toShow = suitable.length > 0 ? suitable.slice(0, 3) : batteries.filter(b => b.surge >= peakSurge).slice(0, 3);

      const recGrid = document.getElementById('rec-grid');
      recGrid.innerHTML = '';
      toShow.forEach(b => {
        const canHandleSurge = b.surge >= peakSurge;
        const canHandleEnergy = b.wh >= batteryNeeded * 0.7;
        const runtime = ((b.wh * 0.8) / (totalRunning * duty + (totalRunning * (1-duty) * 0.1))).toFixed(1);

        const div = document.createElement('div');
        div.className = 'rec-card' + (b.topPick ? ' top-pick' : '');
        div.innerHTML = `
          ${b.topPick ? '<div class="top-pick-badge">Best Match</div>' : ''}
          <div class="rec-name">${b.name}</div>
          <div class="rec-capacity">${b.wh.toLocaleString()} Wh — ${b.surge.toLocaleString()}W surge</div>
          <div class="rec-stats">
            <div class="rec-stat">
              <span class="rec-stat-label">Handles your surge</span>
              <span class="rec-stat-val ${canHandleSurge ? 'ok' : 'bad'}">${canHandleSurge ? '✓ Yes' : '✗ No'}</span>
            </div>
            <div class="rec-stat">
              <span class="rec-stat-label">Enough capacity</span>
              <span class="rec-stat-val ${canHandleEnergy ? 'ok' : 'warn'}">${canHandleEnergy ? '✓ Yes' : '⚠ Borderline'}</span>
            </div>
            <div class="rec-stat">
              <span class="rec-stat-label">Est. runtime</span>
              <span class="rec-stat-val">${runtime}h</span>
            </div>
          </div>
          <a href="${b.link}" target="_blank" rel="noopener" class="rec-link">View on Amazon →</a>`;
        recGrid.appendChild(div);
      });

      if (toShow.length === 0) {
        recGrid.innerHTML = '<p style="color:var(--muted)">No single battery matches your load. Consider a whole-home generator or split your circuits.</p>';
      }

      // Verdict
      const verdictBadge = document.getElementById('verdict-badge');
      const verdictText = document.getElementById('verdict-text');
      if (peakSurge <= 1500) {
        verdictBadge.className = 'verdict-badge verdict-safe';
        verdictBadge.textContent = '✓ Standard Load';
        verdictText.textContent = 'Good news — your surge load is manageable. Most 1kWh+ portable batteries will handle this.';
      } else if (peakSurge <= 3000) {
        verdictBadge.className = 'verdict-badge verdict-caution';
        verdictBadge.textContent = '⚠ High Surge Load';
        verdictText.textContent = 'Your appliances require a high-surge battery. Choose carefully — many budget units will trip.';
      } else {
        verdictBadge.className = 'verdict-badge verdict-danger';
        verdictBadge.textContent = '⛔ Extreme Surge Load';
        verdictText.textContent = 'This load requires a professional-grade battery or whole-home generator. Standard units will fail.';
      }

      // Update display
      document.getElementById('r-surge').textContent = peakSurge.toLocaleString() + 'W';
      document.getElementById('r-running').textContent = totalRunning.toLocaleString() + 'W';
      document.getElementById('r-battery').textContent = (batteryNeeded / 1000).toFixed(1) + ' kWh';

      document.getElementById('processing').style.display = 'none';
      document.getElementById('results-panel').style.display = 'block';
    }, 1800);
  }

  function resetCalc() {
    document.getElementById('results-panel').style.display = 'none';
    document.getElementById('step-voltage').style.display = 'block';
    document.querySelectorAll('.card').forEach(c => c.style.display = 'block');
    document.querySelectorAll('.calc-btn').forEach(b => b.style.display = 'block');
    document.querySelectorAll('.appliance-item').forEach(i => i.classList.remove('selected'));
  }
</script>

</body>
</html>
