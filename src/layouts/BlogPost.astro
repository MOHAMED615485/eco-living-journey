---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={heroImage.width} height={heroImage.height} src={heroImage.src} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />

		<style is:global>
			/* MAGIC RULE: STOPS ANYTHING FROM PUSHING OFF THE SCREEN */
			*, *::before, *::after {
				box-sizing: border-box !important;
			}

			main {
				width: 100%;
				max-width: 800px;
				margin: 0 auto;
				padding: 1rem; 
				background: #ffffff;
				font-size: 1.2rem; 
				line-height: 1.6;
				color: #333;
				overflow-x: hidden;
			}

			/* FORCES IMAGES TO FIT PHONE SCREEN */
			main img {
				display: block;
				margin: 2rem auto !important;
				max-width: 100% !important;
				height: auto !important;
				border-radius: 12px;
			}

			/* TABLE SQUEEZE FIX */
			main table {
				width: 100% !important;
				max-width: 100% !important;
				border-collapse: collapse !important; 
				margin: 2rem 0;
				border: 4px solid #4caf50 !important; 
				display: table; 
				table-layout: fixed !important; 
			}
			main th {
				background-color: #4caf50 !important;
				color: white !important;
				padding: 10px 5px !important; 
				border: 2px solid #388e3c !important; 
				text-align: left;
				font-size: 1rem;
			}
			main td {
				padding: 10px 5px !important;
				border: 2px solid #e0e0e0 !important; 
				font-size: 1rem;
				word-wrap: break-word !important; 
			}
			main tr:nth-child(even) {
				background-color: #f1f8e9 !important; 
			}

			/* BUTTON & AUTHOR BOX */
			.cta-container { text-align: center; margin: 3rem 0; width: 100%; }
			.cta-button {
				display: block;
				width: 95%; 
				margin: 0 auto;
				background: #ff9800;
				color: white !important;
				padding: 18px 10px;
				border-radius: 50px;
				text-decoration: none !important;
				font-weight: bold;
				font-size: 1.2rem;
				box-shadow: 0 4px 12px rgba(255, 152, 0, 0.3);
			}
			.author-box {
				background: #e3f2fd;
				padding: 20px;
				border-radius: 10px;
				margin-top: 3rem;
				border-left: 5px solid #2196f3;
				width: 100%;
			}

			.title { margin-bottom: 2rem; }
			.title h1 { font-size: 2.5rem; line-height: 1.2; margin: 0.5rem 0; }
			.date { color: #666; font-size: 0.9rem; }
			hr { border: none; border-top: 1px solid #eee; margin: 1rem 0; }
		</style>
	</body>
</html>