---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, heroImage } = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
<style>
	main {
		width: calc(100% - 2em);
		max-width: 800px;
		margin: 0 auto;
		background: #ffffff;
		padding: 3rem 2rem;
		border-radius: 16px;
		box-shadow: 0 15px 45px rgba(0,0,0,0.03);
        line-height: 1.8;
	}
	/* CENTER IMAGES & INFOGRAPHICS */
	.prose img {
		display: block;
		margin: 3.5rem auto !important;
		border-radius: 12px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.1);
		max-width: 100%;
	}
	/* PREMIUM CTA BUTTON SYSTEM */
	.cta-container {
		text-align: center;
		margin: 4rem 0;
		padding: 40px;
		background: #f9fbf9;
		border-radius: 20px;
		border: 1px solid #eef2ee;
	}
	.cta-button {
		display: inline-block;
		background: #2d5a27; /* Eco Green */
		color: white !important;
		padding: 22px 50px;
		border-radius: 100px;
		text-decoration: none !important;
		font-weight: 800;
		font-size: 1.3rem;
		box-shadow: 0 10px 25px rgba(45, 90, 39, 0.2);
		transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}
	.cta-button:hover {
		transform: scale(1.05) translateY(-5px);
		box-shadow: 0 15px 35px rgba(45, 90, 39, 0.3);
	}
    .cta-subtext {
        margin-top: 15px;
        font-size: 0.9rem;
        color: #7f8c8d;
    }
	/* AUTHOR BOX STYLING */
	.author-box {
		background: #f4f7f4;
		padding: 25px;
		border-radius: 12px;
		margin-top: 4rem;
	}
</style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <div class="hero-image">
                    {heroImage && <img width={1020} height={510} src={heroImage.src} alt={title} />}
                </div>
                <div class="prose">
                    <div class="title">
                        <div class="date">
                            <FormattedDate date={pubDate} />
                        </div>
                        <h1>{title}</h1>
                        <hr />
                    </div>
                    <slot />
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>