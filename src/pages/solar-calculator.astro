---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
  <head>
    <BaseHead
      title="Solar Generator Sizing Calculator — Find Your Perfect Match"
      description="Free tool by Ethan. Enter your appliances, freezer LRA, and backup hours. Get an exact solar generator recommendation based on 73 days of real testing."
    />
    <script defer src="https://f.convertkit.com/ckjs/ck.5.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
      :root {
        --green: #2d6a4f; --green-mid: #3d8b6f; --green-light: #a8d5b5;
        --green-pale: #d8f0e3; --cream: #f5f0dc; --cream-dark: #ede8d0;
        --text: #1a3d2b; --text-muted: #5a7a68; --orange: #e8790a;
        --shadow: 0 4px 24px rgba(45,106,79,0.12);
        --shadow-lg: 0 12px 48px rgba(45,106,79,0.18);
      }
      *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
      body{font-family:"DM Sans",sans-serif;background:var(--cream);color:var(--text);}
      .hero{background:var(--green);padding:48px 24px 56px;text-align:center;position:relative;overflow:hidden;}
      .hero-badge{display:inline-block;background:rgba(255,255,255,0.15);color:var(--green-light);font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;padding:6px 16px;border-radius:20px;margin-bottom:20px;}
      .hero h1{font-family:"DM Serif Display",serif;font-size:clamp(28px,5vw,48px);color:white;line-height:1.1;margin-bottom:16px;}
      .hero h1 em{font-style:italic;color:var(--green-light);}
      .hero p{color:rgba(255,255,255,0.75);font-size:16px;max-width:560px;margin:0 auto 24px;line-height:1.6;}
      .hero-stats{display:flex;justify-content:center;gap:32px;}
      .hero-stat-num{font-family:"DM Serif Display",serif;font-size:28px;color:var(--green-light);line-height:1;}
      .hero-stat-label{font-size:11px;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:1px;margin-top:4px;}
      .container{max-width:900px;margin:0 auto;padding:0 16px 80px;}
      .steps-nav{display:flex;align-items:center;justify-content:center;gap:0;padding:32px 0 24px;}
      .step-dot{display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;}
      .step-circle{width:36px;height:36px;border-radius:50%;background:var(--cream-dark);border:2px solid var(--green-light);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:var(--text-muted);transition:all 0.3s;}
      .step-dot.active .step-circle{background:var(--green);border-color:var(--green);color:white;transform:scale(1.1);box-shadow:0 0 0 4px var(--green-pale);}
      .step-dot.done .step-circle{background:var(--green-mid);border-color:var(--green-mid);color:white;}
      .step-label{font-size:11px;font-weight:500;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap;}
      .step-dot.active .step-label{color:var(--green);font-weight:600;}
      .step-line{flex:1;height:2px;background:var(--green-light);max-width:80px;margin-bottom:22px;opacity:0.4;}
      .card{background:white;border-radius:20px;padding:32px;box-shadow:var(--shadow);margin-bottom:20px;border:1px solid rgba(168,213,181,0.3);}
      .card-title{font-family:"DM Serif Display",serif;font-size:22px;color:var(--text);margin-bottom:6px;}
      .card-subtitle{font-size:14px;color:var(--text-muted);margin-bottom:24px;line-height:1.5;}
      .step-panel{display:none;}
      .step-panel.active{display:block;animation:fadeIn 0.3s ease;}
      @keyframes fadeIn{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
      .appliances-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;margin-bottom:20px;}
      .appliance-item{background:var(--cream);border:2px solid transparent;border-radius:14px;padding:16px;cursor:pointer;transition:all 0.2s;position:relative;}
      .appliance-item:hover{border-color:var(--green-light);background:var(--green-pale);}
      .appliance-item.selected{border-color:var(--green);background:var(--green-pale);}
      .appliance-icon{font-size:28px;margin-bottom:8px;}
      .appliance-name{font-size:14px;font-weight:600;color:var(--text);margin-bottom:2px;}
      .appliance-watts{font-size:12px;color:var(--text-muted);}
      .add-custom{background:white;border:2px dashed var(--green-light);border-radius:14px;padding:16px;cursor:pointer;transition:all 0.2s;text-align:center;}
      .add-custom:hover{border-color:var(--green);background:var(--green-pale);}
      .watt-input-row{display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(--cream);border-radius:12px;margin-bottom:10px;}
      .watt-input-icon{font-size:20px;width:28px;}
      .watt-input-name{flex:1;font-size:14px;font-weight:500;}
      .watt-input-label{font-size:11px;color:var(--text-muted);min-width:60px;text-align:right;}
      .watt-input{width:90px;padding:8px 12px;border:2px solid var(--green-light);border-radius:8px;font-size:14px;font-weight:600;text-align:center;background:white;}
      .watt-input:focus{outline:none;border-color:var(--green);}
      .lra-box{background:linear-gradient(135deg,var(--green) 0%,var(--green-mid) 100%);border-radius:16px;padding:24px;color:white;margin-bottom:20px;}
      .lra-box h3{font-family:"DM Serif Display",serif;font-size:18px;margin-bottom:8px;}
      .lra-box p{font-size:13px;opacity:0.8;margin-bottom:20px;line-height:1.5;}
      .lra-inputs{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
      .lra-field label{display:block;font-size:11px;opacity:0.7;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;}
      .lra-field input{width:100%;padding:10px 14px;border:2px solid rgba(255,255,255,0.3);border-radius:10px;background:rgba(255,255,255,0.15);color:white;font-size:16px;font-weight:600;text-align:center;}
      .lra-field input::placeholder{color:rgba(255,255,255,0.4);}
      .lra-field input:focus{outline:none;border-color:white;}
      .lra-result{margin-top:16px;background:rgba(255,255,255,0.15);border-radius:10px;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;}
      .lra-result-label{font-size:13px;opacity:0.8;}
      .lra-result-value{font-family:"DM Serif Display",serif;font-size:24px;color:var(--green-light);}
      .hours-section{margin-bottom:20px;}
      .hours-label{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
      .hours-value{font-family:"DM Serif Display",serif;font-size:24px;color:var(--green);}
      input[type=range]{width:100%;height:6px;appearance:none;background:var(--green-light);border-radius:3px;outline:none;cursor:pointer;}
      input[type=range]::-webkit-slider-thumb{appearance:none;width:22px;height:22px;border-radius:50%;background:var(--green);cursor:pointer;border:3px solid white;}
      .live-summary{background:var(--cream);border-radius:14px;padding:20px;border:1px solid rgba(168,213,181,0.4);}
      .live-summary-title{font-size:12px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:14px;}
      .live-summary-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid rgba(168,213,181,0.3);font-size:14px;}
      .live-summary-row:last-child{border-bottom:none;}
      .live-summary-row span:first-child{color:var(--text-muted);}
      .val{font-weight:700;color:var(--text);}
      .btn-primary{display:block;width:100%;padding:18px;background:var(--green);color:white;border:none;border-radius:50px;font-size:16px;font-weight:600;cursor:pointer;margin-top:24px;}
      .btn-primary:hover{background:var(--green-mid);}
      .btn-secondary{display:inline-block;padding:12px 24px;background:transparent;color:var(--green);border:2px solid var(--green-light);border-radius:50px;font-size:14px;font-weight:600;cursor:pointer;margin-right:12px;}
      .btn-secondary:hover{border-color:var(--green);background:var(--green-pale);}
      .results-header{text-align:center;padding:32px 0 16px;}
      .results-header h2{font-family:"DM Serif Display",serif;font-size:28px;color:var(--text);margin-bottom:8px;}
      .requirement-box{background:var(--green);border-radius:20px;padding:28px;color:white;margin-bottom:24px;display:grid;grid-template-columns:repeat(3,1fr);gap:20px;text-align:center;}
      .req-item-label{font-size:11px;opacity:0.7;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
      .req-item-value{font-family:"DM Serif Display",serif;font-size:28px;color:var(--green-light);line-height:1;}
      .req-item-unit{font-size:12px;opacity:0.6;margin-top:4px;}
      .products-grid{display:grid;gap:16px;margin-bottom:24px;}
      .product-card{background:white;border-radius:20px;padding:24px;box-shadow:var(--shadow);border:2px solid transparent;position:relative;}
      .product-card.recommended{border-color:var(--green);box-shadow:var(--shadow-lg);}
      .recommended-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--green);color:white;font-size:11px;font-weight:700;padding:5px 16px;border-radius:20px;white-space:nowrap;}
      .product-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;gap:12px;}
      .product-name{font-family:"DM Serif Display",serif;font-size:18px;color:var(--text);margin-bottom:4px;}
      .product-tagline{font-size:12px;color:var(--text-muted);}
      .product-match{text-align:right;flex-shrink:0;}
      .match-score{font-family:"DM Serif Display",serif;font-size:28px;color:var(--green);line-height:1;}
      .match-label{font-size:10px;color:var(--text-muted);text-transform:uppercase;}
      .product-specs{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;}
      .spec-item{background:var(--cream);border-radius:10px;padding:10px 8px;text-align:center;}
      .spec-value{font-size:13px;font-weight:700;color:var(--text);margin-bottom:3px;}
      .spec-label{font-size:10px;color:var(--text-muted);text-transform:uppercase;}
      .product-verdict{background:var(--cream);border-radius:10px;padding:12px 14px;font-size:13px;color:var(--text-muted);line-height:1.5;margin-bottom:16px;border-left:3px solid var(--green-light);}
      .product-verdict strong{color:var(--text);}
      .status-pass{display:inline-flex;font-size:11px;font-weight:600;color:#27ae60;background:#e8f8f0;padding:3px 10px;border-radius:20px;margin-bottom:12px;}
      .status-warn{display:inline-flex;font-size:11px;font-weight:600;color:#e67e22;background:#fef5e7;padding:3px 10px;border-radius:20px;margin-bottom:12px;}
      .btn-amazon{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:16px;background:#e8790a;color:white;border:none;border-radius:50px;font-size:15px;font-weight:700;cursor:pointer;text-decoration:none;}
      .btn-amazon:hover{background:#c96a08;}
      .ethan-note{background:var(--cream);border-radius:16px;padding:20px 24px;display:flex;gap:16px;align-items:flex-start;margin-bottom:24px;border:1px solid rgba(168,213,181,0.4);}
      .ethan-avatar{width:44px;height:44px;border-radius:50%;background:var(--green);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
      .ethan-note-text{font-size:14px;color:var(--text-muted);line-height:1.6;}
      .ethan-note-text strong{color:var(--text);}
      .disclaimer{font-size:11px;color:var(--text-muted);text-align:center;padding:16px;line-height:1.5;opacity:0.7;}
      .reset-btn{display:block;text-align:center;color:var(--text-muted);font-size:13px;cursor:pointer;padding:12px;text-decoration:underline;}
      .kit-section{max-width:700px;margin:40px auto;padding:0 16px 60px;}
      @media(max-width:600px){
        .appliances-grid{grid-template-columns:1fr 1fr;}
        .product-specs{grid-template-columns:repeat(2,1fr);}
        .requirement-box{grid-template-columns:1fr;}
        .lra-inputs{grid-template-columns:1fr;}
        .card{padding:20px;}
      }
    </style>
  </head>
  <body>
    <Header />

    <div class="hero">
      <div class="hero-badge">Free Tool by Eco Living Journey</div>
      <h1>Find Your <em>Perfect</em><br>Solar Generator</h1>
      <p>Tell me what you need to power. I will tell you exactly which generator handles it based on 73 days of real testing.</p>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="hero-stat-num">73</div>
          <div class="hero-stat-label">Days Tested</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">3</div>
          <div class="hero-stat-label">Brands Compared</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">100%</div>
          <div class="hero-stat-label">Free Tool</div>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="steps-nav">
        <div class="step-dot active" id="nav-1" onclick="goToStep(1)">
          <div class="step-circle">1</div>
          <div class="step-label">Appliances</div>
        </div>
        <div class="step-line"></div>
        <div class="step-dot" id="nav-2" onclick="goToStep(2)">
          <div class="step-circle">2</div>
          <div class="step-label">Watts</div>
        </div>
        <div class="step-line"></div>
        <div class="step-dot" id="nav-3" onclick="goToStep(3)">
          <div class="step-circle">3</div>
          <div class="step-label">Freezer LRA</div>
        </div>
        <div class="step-line"></div>
        <div class="step-dot" id="nav-4" onclick="goToStep(4)">
          <div class="step-circle">4</div>
          <div class="step-label">Results</div>
        </div>
      </div>

      <div class="step-panel active" id="step-1">
        <div class="card">
          <div class="card-title">What do you need to power?</div>
          <div class="card-subtitle">Select everything you want to keep running during a blackout.</div>
          <div class="appliances-grid" id="applianceGrid"></div>
          <div class="add-custom" onclick="addCustomAppliance()">
            <div style="font-size:24px;margin-bottom:6px;">+</div>
            <div style="font-size:13px;font-weight:600;color:var(--green);">Add Custom Appliance</div>
            <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">Enter your own watts</div>
          </div>
        </div>
        <button class="btn-primary" onclick="goToStep(2)">Continue - Adjust Watt Values</button>
      </div>

      <div class="step-panel" id="step-2">
        <div class="card">
          <div class="card-title">Confirm your watt values</div>
          <div class="card-subtitle">Update these with your actual appliance labels for an exact result.</div>
          <div id="wattInputsList"></div>
          <div class="live-summary">
            <div class="live-summary-title">Live Calculation</div>
            <div class="live-summary-row"><span>Total running watts</span><span class="val" id="sumRunning">0W</span></div>
            <div class="live-summary-row"><span>Recommended capacity</span><span class="val" id="sumCapacity">0 Wh</span></div>
          </div>
        </div>
        <div style="display:flex;gap:12px;margin-top:24px;">
          <button class="btn-secondary" onclick="goToStep(1)">Back</button>
          <button class="btn-primary" style="margin-top:0;flex:1" onclick="goToStep(3)">Continue - Freezer Surge Check</button>
        </div>
      </div>

      <div class="step-panel" id="step-3">
        <div class="lra-box">
          <h3>The Surge Number That Saves Your Food</h3>
          <p>Every freezer and fridge has an LRA number on its data plate. This is the surge amps the compressor needs to start. Miss this and your generator trips at 2AM.</p>
          <div class="lra-inputs">
            <div class="lra-field">
              <label>Freezer LRA (from data plate)</label>
              <input type="number" id="freezerLRA" placeholder="e.g. 8.3" step="0.1" min="0" oninput="calcLRA()" />
            </div>
            <div class="lra-field">
              <label>Fridge LRA (if applicable)</label>
              <input type="number" id="fridgeLRA" placeholder="e.g. 6.5" step="0.1" min="0" oninput="calcLRA()" />
            </div>
          </div>
          <div class="lra-result">
            <div>
              <div class="lra-result-label">Minimum surge watts required</div>
              <div style="font-size:11px;opacity:0.6;margin-top:2px;">LRA x 120 = surge watts</div>
            </div>
            <div class="lra-result-value" id="surgeResult">Enter LRA</div>
          </div>
        </div>
        <div class="card">
          <div class="card-title">How long do you need backup?</div>
          <div class="card-subtitle">How many hours of runtime on a single charge?</div>
          <div class="hours-section">
            <div class="hours-label">
              <span>Required backup hours</span>
              <span class="hours-value" id="hoursDisplay">12 hours</span>
            </div>
            <input type="range" id="hoursSlider" min="4" max="48" value="12" step="2" oninput="updateHours()" />
            <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text-muted);margin-top:6px;">
              <span>4h (short)</span><span>24h (full day)</span><span>48h (extended)</span>
            </div>
          </div>
          <div class="live-summary">
            <div class="live-summary-title">Your Requirements Summary</div>
            <div class="live-summary-row"><span>Total running watts</span><span class="val" id="finalRunning">0W</span></div>
            <div class="live-summary-row"><span>Surge watts needed</span><span class="val" id="finalSurge">Not set</span></div>
            <div class="live-summary-row"><span>Backup hours needed</span><span class="val" id="finalHours">12h</span></div>
            <div class="live-summary-row"><span>Minimum battery capacity</span><span class="val" id="finalCapacity">0 Wh</span></div>
          </div>
        </div>
        <div style="display:flex;gap:12px;margin-top:24px;">
          <button class="btn-secondary" onclick="goToStep(2)">Back</button>
          <button class="btn-primary" style="margin-top:0;flex:1" onclick="calculateResults()">Find My Generator</button>
        </div>
      </div>

      <div class="step-panel" id="step-4">
        <div class="results-header">
          <h2>Your Generator Match</h2>
          <p>Based on your real power requirements</p>
        </div>
        <div class="requirement-box">
          <div><div class="req-item-label">Running Watts</div><div class="req-item-value" id="resRunning">0</div><div class="req-item-unit">watts</div></div>
          <div><div class="req-item-label">Surge Required</div><div class="req-item-value" id="resSurge">0</div><div class="req-item-unit">watts</div></div>
          <div><div class="req-item-label">Battery Needed</div><div class="req-item-value" id="resCapacity">0</div><div class="req-item-unit">watt-hours</div></div>
        </div>
        <div class="ethan-note">
          <div class="ethan-avatar">E</div>
          <div class="ethan-note-text" id="ethanNote">Loading analysis...</div>
        </div>
        <div class="products-grid" id="productsGrid"></div>
        <div class="disclaimer">As an Amazon Associate I earn from qualifying purchases at no extra cost to you. All recommendations based on 73 days of real testing.</div>
        <span class="reset-btn" onclick="resetCalculator()">Start over with different appliances</span>
      </div>
    </div>

    <div class="kit-section">
      <form action="https://app.kit.com/forms/9163556/subscriptions" class="seva-form formkit-form" method="post" data-sv-form="9163556" data-uid="c7ed9c1a27" data-format="inline" data-version="5" min-width="400 500 600 700 800" style="background-color:rgb(249,250,251);border-radius:4px;">
        <div data-style="minimal">
          <div class="formkit-header" style="color:rgb(0,0,0);font-size:21px;font-weight:700;text-align:center;padding:20px 20px 0;">
            <h2>The Blackout-Proof Home Checklist ⚡🏡</h2>
          </div>
          <div class="formkit-subheader" style="color:rgb(62,62,62);font-size:18px;text-align:center;padding:10px 20px;">
            <p>Join 1,000+ homeowners getting my exact gear list to keep their fridge, Wi-Fi, and lights running during a blackout.</p>
          </div>
          <div data-element="fields" class="seva-fields formkit-fields" style="display:flex;flex-wrap:wrap;margin:16px 20px;gap:10px;">
            <div class="formkit-field" style="flex:1 0 200px;">
              <input class="formkit-input" name="email_address" aria-label="Email Address" placeholder="Email Address" required type="email" style="width:100%;padding:12px 16px;border:1px solid #e3e3e3;border-radius:50px;font-size:15px;" />
            </div>
            <button data-element="submit" class="formkit-submit" style="background-color:rgb(45,106,79);color:white;border:none;border-radius:50px;padding:12px 24px;font-size:15px;font-weight:600;cursor:pointer;">
              SEND ME THE CHECKLIST
            </button>
          </div>
          <div style="color:rgb(77,77,77);font-size:13px;text-align:center;padding:0 20px 20px;">We will not send you spam. Unsubscribe at any time.</div>
        </div>
      </form>
    </div>

    <Footer />
<script is:inline>      const APPLIANCES = [
        {id:"chest-freezer",icon:"🧊",name:"Chest Freezer",watts:100,surge:1000},
        {id:"upright-fridge",icon:"🍎",name:"Refrigerator",watts:150,surge:1200},
        {id:"lights-led",icon:"💡",name:"LED Lights (4)",watts:40,surge:40},
        {id:"router",icon:"📡",name:"Wi-Fi Router",watts:15,surge:15},
        {id:"phone-charge",icon:"📱",name:"Phone Charging",watts:20,surge:20},
        {id:"laptop",icon:"💻",name:"Laptop",watts:65,surge:65},
        {id:"cpap",icon:"😮",name:"CPAP Machine",watts:30,surge:30},
        {id:"tv",icon:"📺",name:"TV 55 inch",watts:100,surge:100},
        {id:"fan",icon:"🌀",name:"Box Fan",watts:75,surge:75},
        {id:"sump-pump",icon:"💧",name:"Sump Pump",watts:800,surge:1800},
        {id:"microwave",icon:"🍲",name:"Microwave",watts:1000,surge:1000},
        {id:"medical",icon:"🏥",name:"Medical Device",watts:150,surge:150}
      ];
      const PRODUCTS = [
        {id:"ecoflow",name:"EcoFlow DELTA 3 Plus",tagline:"Best Overall - Ethan's #1 Pick",capacity:1024,acOutput:1800,surgeOutput:2500,weight:"12.3kg",link:"https://amzn.to/41D10iO",ethanNote:"This is the unit I ran for 73 days straight. The X-Boost surge handling is what makes it special - it handled every startup without tripping once."},
        {id:"jackery",name:"Jackery Explorer 1000 V2",tagline:"Best Value - Solid Mid-Range",capacity:1070,acOutput:2000,surgeOutput:4000,weight:"11.8kg",link:"https://amzn.to/47Esd8d",ethanNote:"Great value if your freezer LRA is under 9.0. Lighter than EcoFlow and slightly larger battery. Check your LRA first."},
        {id:"bluetti",name:"Bluetti AC200L",tagline:"Best Capacity - Whole-Home Backup",capacity:2048,acOutput:2400,surgeOutput:3600,weight:"28kg",link:"https://amzn.to/4sFpOCG",ethanNote:"I ran my full setup - chest freezer, fridge, 4 lights, router - for 11.2 hours on one charge. If you need real whole-home backup this is it."}
      ];
      let selectedAppliances = new Set();
      let customAppliances = [];

      function init() { renderApplianceGrid(); }

      function renderApplianceGrid() {
        const grid = document.getElementById("applianceGrid");
        const all = [...APPLIANCES, ...customAppliances];
        grid.innerHTML = all.map(a => `
          <div class="appliance-item ${selectedAppliances.has(a.id) ? "selected" : ""}"
               onclick="toggleAppliance('${a.id}')">
            <div class="appliance-icon">${a.icon}</div>
            <div class="appliance-name">${a.name}</div>
            <div class="appliance-watts">${a.watts}W running</div>
          </div>`).join("");
      }

      function toggleAppliance(id) {
        if (selectedAppliances.has(id)) { selectedAppliances.delete(id); }
        else { selectedAppliances.add(id); }
        renderApplianceGrid();
      }

      function addCustomAppliance() {
        const name = prompt("Appliance name:");
        if (!name) return;
        const watts = parseInt(prompt("Running watts:"));
        if (!watts || isNaN(watts)) return;
        const id = "custom-" + Date.now();
        customAppliances.push({id, icon:"🔌", name, watts, surge: watts * 1.5});
        selectedAppliances.add(id);
        renderApplianceGrid();
      }

      function goToStep(n) {
        if (n === 2 && selectedAppliances.size === 0) { alert("Please select at least one appliance."); return; }
        if (n === 2) renderWattInputs();
        if (n === 3) updateStep3Summary();
        document.querySelectorAll(".step-panel").forEach(p => p.classList.remove("active"));
        document.getElementById("step-" + n).classList.add("active");
        document.querySelectorAll(".step-dot").forEach((d, i) => {
          d.classList.remove("active", "done");
          if (i + 1 < n) d.classList.add("done");
          if (i + 1 === n) d.classList.add("active");
        });
        window.scrollTo({top: 0, behavior: "smooth"});
      }

      function getAllSelected() {
        return [...APPLIANCES, ...customAppliances].filter(a => selectedAppliances.has(a.id));
      }

      function renderWattInputs() {
        const list = document.getElementById("wattInputsList");
        list.innerHTML = getAllSelected().map(a => `
          <div class="watt-input-row">
            <div class="watt-input-icon">${a.icon}</div>
            <div class="watt-input-name">${a.name}</div>
            <div class="watt-input-label">Running W</div>
            <input class="watt-input" type="number" id="watts-${a.id}" value="${a.watts}" min="1" max="5000" oninput="updateWattCalc()">
          </div>`).join("");
        updateWattCalc();
      }

      function updateWattCalc() {
        const sel = getAllSelected();
        let total = 0;
        sel.forEach(a => { const el = document.getElementById("watts-" + a.id); if (el) { a.watts = parseInt(el.value) || a.watts; total += a.watts; }});
        const hours = parseInt(document.getElementById("hoursSlider")?.value || 12);
        document.getElementById("sumRunning").textContent = total + "W";
        document.getElementById("sumCapacity").textContent = Math.round(total * hours * 1.25).toLocaleString() + " Wh";
      }

      function calcLRA() {
        const l1 = parseFloat(document.getElementById("freezerLRA").value) || 0;
        const l2 = parseFloat(document.getElementById("fridgeLRA").value) || 0;
        const surge = Math.round(Math.max(l1, l2) * 120);
        document.getElementById("surgeResult").textContent = surge > 0 ? surge.toLocaleString() + "W" : "Enter LRA";
        updateStep3Summary();
      }

      function updateHours() {
        const h = document.getElementById("hoursSlider").value;
        document.getElementById("hoursDisplay").textContent = h + " hours";
        document.getElementById("finalHours").textContent = h + "h";
        updateStep3Summary();
      }

      function updateStep3Summary() {
        const sel = getAllSelected();
        const total = sel.reduce((s, a) => s + a.watts, 0);
        const l1 = parseFloat(document.getElementById("freezerLRA")?.value) || 0;
        const l2 = parseFloat(document.getElementById("fridgeLRA")?.value) || 0;
        const surge = Math.round(Math.max(l1, l2) * 120);
        const hours = parseInt(document.getElementById("hoursSlider")?.value || 12);
        document.getElementById("finalRunning").textContent = total + "W";
        document.getElementById("finalSurge").textContent = surge > 0 ? surge.toLocaleString() + "W" : "Not entered";
        document.getElementById("finalHours").textContent = hours + "h";
        document.getElementById("finalCapacity").textContent = Math.round(total * hours * 1.25).toLocaleString() + " Wh";
      }

      function calculateResults() {
        const sel = getAllSelected();
        const totalRunning = sel.reduce((s, a) => s + a.watts, 0);
        const l1 = parseFloat(document.getElementById("freezerLRA").value) || 0;
        const l2 = parseFloat(document.getElementById("fridgeLRA").value) || 0;
        const maxSurge = Math.round(Math.max(l1, l2) * 120);
        const hours = parseInt(document.getElementById("hoursSlider").value);
        const minCap = Math.round(totalRunning * hours * 1.25);
        document.getElementById("resRunning").textContent = totalRunning;
        document.getElementById("resSurge").textContent = maxSurge > 0 ? maxSurge.toLocaleString() : "N/A";
        document.getElementById("resCapacity").textContent = minCap.toLocaleString();
        const scored = PRODUCTS.map(p => {
          let score = 100; let issues = []; let pass = true;
          if (p.capacity < minCap) { const d = minCap - p.capacity; score -= Math.min(40, (d / minCap) * 60); if (d > 200) { issues.push("Capacity may be tight for " + hours + " hours"); pass = false; }}
          if (maxSurge > 0 && p.surgeOutput < maxSurge) { score -= 50; issues.push("Surge output too low for your LRA"); pass = false; }
          if (p.acOutput < totalRunning) { score -= 40; issues.push("AC output may not cover all appliances simultaneously"); }
          return {...p, score: Math.max(0, Math.round(score)), issues, pass};
        }).sort((a, b) => b.score - a.score);
        const best = scored[0];
        let note = "";
        if (totalRunning < 300 && minCap < 1200) { note = `<strong>Good news</strong> - your setup is manageable. At only ${totalRunning}W, ${best.name} handles this comfortably.`; }
        else if (totalRunning > 1000) { note = `<strong>Heavy load detected.</strong> At ${totalRunning}W running draw, the Bluetti AC200L is built for setups like yours.`; }
        else { note = `Based on ${totalRunning}W load and ${minCap}Wh needed for ${hours} hours, <strong>${best.name} is your best match.</strong>`; }
        document.getElementById("ethanNote").innerHTML = note;
        document.getElementById("productsGrid").innerHTML = scored.map((p, i) => `
          <div class="product-card ${i === 0 ? "recommended" : ""}">
            ${i === 0 ? '<div class="recommended-badge">Best Match for Your Setup</div>' : ""}
            <div class="product-header">
              <div><div class="product-name">${p.name}</div><div class="product-tagline">${p.tagline}</div></div>
              <div class="product-match"><div class="match-score">${p.score}%</div><div class="match-label">Match</div></div>
            </div>
            <div class="${p.pass ? "status-pass" : "status-warn"}">${p.pass ? "Handles your load" : "Check requirements"}</div>
            <div class="product-specs">
              <div class="spec-item"><div class="spec-value">${p.capacity.toLocaleString()}</div><div class="spec-label">Wh Battery</div></div>
              <div class="spec-item"><div class="spec-value">${(p.acOutput/1000).toFixed(1)}kW</div><div class="spec-label">AC Output</div></div>
              <div class="spec-item"><div class="spec-value">${(p.surgeOutput/1000).toFixed(1)}kW</div><div class="spec-label">Surge</div></div>
              <div class="spec-item"><div class="spec-value">${p.weight}</div><div class="spec-label">Weight</div></div>
            </div>
            <div class="product-verdict"><strong>Ethan says:</strong> ${p.ethanNote}${p.issues.length > 0 ? "<br><br><strong>Note:</strong> " + p.issues.join(" - ") : ""}</div>
            <a href="${p.link}" target="_blank" rel="nofollow" class="btn-amazon">Check Current Price on Amazon</a>
          </div>`).join("");
        goToStep(4);
      }

      function resetCalculator() {
        selectedAppliances.clear(); customAppliances = [];
        document.getElementById("freezerLRA").value = "";
        document.getElementById("fridgeLRA").value = "";
        document.getElementById("hoursSlider").value = 12;
        document.getElementById("hoursDisplay").textContent = "12 hours";
        renderApplianceGrid(); goToStep(1);
      }

      init();
    </script>
  </body>
</html>