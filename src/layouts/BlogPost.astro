---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />

<style>
	main {
		width: 100%;
		max-width: 800px;
		margin: 0 auto;
		padding: 1rem; /* More space for small phone screens */
		background: #ffffff;
		font-size: 1.3rem; /* Nice big text for easy reading */
		line-height: 1.6;
		color: #333;
	}

	/* FIX: IMAGES MUST FIT THE PHONE SCREEN */
	.prose img {
		display: block;
		margin: 2rem auto !important;
		max-width: 100% !important; /* Forces it to stay inside the phone edges */
		height: auto !important; /* Keeps the picture from looking squashed */
		border-radius: 12px;
		box-shadow: 0 4px 15px rgba(0,0,0,0.1);
	}

	/* TABLE: SOLID LINES & CHEERFUL COLORS */
	.prose table {
		width: 100%;
		border-collapse: collapse !important; /* This forces the lines to show */
		margin: 2.5rem 0;
		border: 3px solid #4caf50 !important; /* Thick Green Outer Line */
	}
	.prose th {
		background-color: #4caf50;
		color: white !important;
		padding: 15px 10px;
		border: 2px solid #388e3c !important; /* Dark Green Lines for Header */
		text-align: left;
		font-size: 1.1rem;
	}
	.prose td {
		padding: 15px 10px;
		border: 2px solid #e0e0e0 !important; /* SOLID GRAY LINES FOR THE TABLE */
		font-size: 1rem;
	}
	.prose tr:nth-child(even) {
		background-color: #f9fdf9; /* Very Light Green Stripe */
	}

	/* CHEERFUL ORANGE BUTTON */
	.cta-container { text-align: center; margin: 4rem 0; }
	.cta-button {
		display: inline-block;
		background: #ff9800;
		color: white !important;
		padding: 20px 40px;
		border-radius: 60px;
		text-decoration: none !important;
		font-weight: bold;
		font-size: 1.4rem;
		box-shadow: 0 6px 20px rgba(255, 152, 0, 0.4);
		transition: transform 0.2s;
	}
	.cta-button:hover { transform: scale(1.05); }

	/* CHEERFUL BIO BOX */
	.author-box {
		background: #e3f2fd;
		padding: 25px;
		border-radius: 15px;
		margin-top: 4rem;
		border: 2px dashed #2196f3;
	}
</style><style>
